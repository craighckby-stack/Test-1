{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://sovereign.agi/schema/state_commit_config_v2.json",
  "title": "N03 State Commit Configuration Schema V2 — NEXUS_CORE Enhanced",
  "type": "object",
  "properties": {
    "state_commit_identification": {
      "type": "object",
      "properties": {
        "commit_name": { "type": "string", "enum": ["AUTOGEN_DEFAULT_V2", "AUTOGEN_DEFAULT_V2_VARIATION_1"] },
        "handler_module": { "type": "string", "description": "Module or class handling state commit, e.g. 'metric_aggregator'" },
        "output_record_type": { "type": "string", "enum": ["STATE_COMMIT_RECORD_V2", "STATE_COMMIT_RECORD_V3"] },
        "extended_commit_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Additional timestamp for auditing and synchronization"
        },
        "commit_hash": { "type": "string", "format": "uri" }
      },
      "required": ["commit_name", "handler_module", "output_record_type"]
    },
    "state_commit_integrity": {
      "type": "object",
      "properties": {
        "transaction_verification": {
          "type": "object",
          "properties": {
            "algorithm": { "type": "string", "enum": ["SHA-256", "SHA-512", "BLAKE2", "ARGON2"] },
            "transaction_salt": { "type": "string", "format": "hex" },
            "transaction_salt_source": { "type": "string", "enum": ["OS", "USER", "MODULE_DIR", "NETWORK_TIMESTAMP"] }
          },
          "required": ["algorithm", "transaction_salt"]
        },
        "data_transformation": {
          "type": "object",
          "properties": {
            "transformation_method": { "type": "string", "enum": ["JSON", "BIN_PACK", "GZIP", "JSON_WEB_TOKEN"] },
            "transformation_standard": { "type": "string", "enum": ["MINIJSON", "JSONLD", "JSON_HYPERSchema"] }
          },
          "required": ["transformation_method", "transformation_standard"]
        },
        "extended_pre_commit_verifier": { "type": "string", "format": "uuid" }
      },
      "required": ["transaction_verification", "data_transformation"]
    },
    "dependent_resources_2": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9_]{5,}$" },
          "path": { "type": "string", "format": "path" },
          "alternative_dependency_status": { "type": "string", "enum": ["PRIMARY", "ALTERNTIVE"] },
          "resource_requirement": {
            "type": "object",
            "required": ["processing", "memory", "disk"],
            "properties": {
              "processing": { "type": "integer", "minimum": 1 },
              "memory": { "type": "integer", "minimum": 1 },
              "disk": { "type": "integer", "minimum": 1 }
            }
          },
          "modified_external_dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "EXTERNAL_DEPENDENCY_1_V3",
                "EXTERNAL_DEPENDENCY_2_V3",
                "EXTERNAL_DEPENDENCY_3_V3"
              ]
            }
          },
          "service_dependency_2": {
            "type": "object",
            "required": ["host", "port", "service_credentials_2"],
            "properties": {
              "host": { "type": "string", "format": "domain" },
              "port": { "type": "integer", "minimum": 1 },
              "service_credentials_2": { "type": "object", "properties": { "service_username_2": { "type": "string" }, "service_password_2": { "type": "string", "format": "password" } }, "required": ["service_username_2", "service_password_2"] }
            }
          }
        },
        "required": ["id", "path", "alternative_dependency_status"]
      },
      "minItems": 1
    }
  },
  "required": ["state_commit_identification", "state_commit_integrity"]
}