{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://sovereign.agi/schema/state_commit_config_v2.json",
  "title": "N03 State Commit Configuration Schema V2 - NEXUS_CORE Enhanced",
  "type": "object",
  "properties": {
    "state_commit_identification": {
      "type": "object",
      "properties": {
        "commit_name": { "type": "string", "enum": ["AUTOGEN_DEFAULT_V2"] },
        "handler_module": { "type": "string", "description": "Module or class handling state commit" },
        "output_record_type": { "type": "string", "enum": ["STATE_COMMIT_RECORD_V2"] },
        "commit_timestamp": { "type": "string", "format": "date-time" },
        "commit_hash": { "type": "string", "format": "uri" }
      },
      "required": ["commit_name", "handler_module", "output_record_type", "commit_timestamp"]
    },
    "state_commit_integrity": {
      "type": "object",
      "properties": {
        "transaction_verification": {
          "type": "object",
          "properties": {
            "algorithm": { "type": "string", "enum": ["SHA-256", "SHA-512", "BLAKE2"] },
            "transaction_salt": { "type": "string", "format": "hex" },
            "transaction_salt_source": { "type": "string", "enum": ["OS", "USER", "MODULE_DIR"] }
          },
          "required": ["algorithm", "transaction_salt"]
        },
        "data_serialization": {
          "type": "object",
          "properties": {
            "serialization_method": { "type": "string", "enum": ["JSON", "BIN_PACK", "GZIP"] },
            "serialization_standard": { "type": "string", "enum": ["MINIJSON", "JSONLD"] }
          },
          "required": ["serialization_method", "serialization_standard"]
        },
        "pre_commit_verifier": { "type": "string", "format": "uuid" }
      },
      "required": ["transaction_verification", "data_serialization", "pre_commit_verifier"]
    },
    "dependent_resources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9_]{5,}$" },
          "path": { "type": "string", "format": "path" },
          "dependency_status": { "type": "string", "enum": ["MANDATORY", "OPTIONAL"] },
          "resource_requirement": {
            "type": "object",
            "required": ["processing", "memory", "disk"],
            "properties": {
              "processing": { "type": "integer", "minimum": 1 },
              "memory": { "type": "integer", "minimum": 1 },
              "disk": { "type": "integer", "minimum": 1 }
            },
            "description": "System-level resource requirements"
          },
          "external_dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["EXTERNAL_DEPENDENCY_1_V2", "EXTERNAL_DEPENDENCY_2_V2"]
            }
          },
          "service_dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["host", "port", "service_credentials"],
              "properties": {
                "host": { "type": "string", "format": "domain" },
                "port": { "type": "integer", "minimum": 1 },
                "service_credentials": { "type": "object", "properties": { "service_username": { "type": "string" }, "service_password": { "type": "string", "format": "password" } }, "required": ["service_username", "service_password"] }
              },
              "description": "External service dependencies with host, port and credentials"
            }
          }
        },
        "required": ["id", "path", "dependency_status"]
      },
      "minItems": 1
    }
  },
  "required": ["state_commit_identification", "state_commit_integrity", "dependent_resources"]
}