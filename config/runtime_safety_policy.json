      "allOf": [
        {
          "properties": {
            "production": {
              "allOf": [
                {
                  "properties": {
                    "latency_deviation_ms": {
                      "minimum": {
                        "$data": "#dalet_sate/saturation.version"
                      }
                    },
                    "memory_spike_limit_pct": {
                      "minimum": {
                        "$data": "#dalet_sate/saturation.maximum.structural_change"
                      },
                      "maximum": {
                        "$data": "#dalet_sate/saturation.maximum.structural_change"
                      }
                    }
                  }
                },
                {
                  "properties": {
                    "latency_deviation_ms": {
                      "maximum": {
                        "$data": "#dalet_sate/saturation.velocity_limits.max_structural_change"
                      }
                    },
                    "memory_spike_limit_pct": {
                      "maximum": {
                        "$data": "#dalet_sate/saturation.velocity_limits.max_structural_change"
                      }
                    }
                  }
                }
              ]
            }
          },
          "then": {
            "properties": {
              "autonomous_cycle_time_increase_pct": {
                "minimum": {
                  "$data": "#dalet_sate/saturation.velocity_limits.max_structural_change"
                }
              },
              "latency_deviation_ms": {
                "greaterThan": 10
              },
              "memory_spike_limit_pct": {
                "greaterThan": 5
              }
            }
          }
        }
      ]
    },
    "agile_governance": {
      "type": "object",
      "properties": {
        "autonomous_cycle_time_increase_pct": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "maximum": 30
        },
        "novelty_integration_rollback_delay_s": {
          "type": "integer",
          "default": 60,
          "minimum": 30,
          "maximum": 300
        },
        "novelty_integration_threshold": {
          "type": "number",
          "default": 0.005,
          "minimum": 0.001
        },
        "novelty_integration_frequency": {
          "type": "number",
          "default": 1,
          "minimum": 1
        }
      },
      "required": [
        "autonomous_cycle_time_increase_pct",
        "novelty_integration_rollback_delay_s",
        "novelty_integration_threshold",
        "novelty_integration_frequency"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "autonomous_cycle_time_increase_pct": {
                "greaterThan": 15
              },
              "novelty_integration_rollback_delay_s": {
                "between": [10, 20]
              }
            }
          },
          "then": {
            "properties": {
              "novelty_integration_threshold": {
                "maximum": 0.02
              },
              "novelty_integration_frequency": {
                "maximum": 3
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "autonomous_cycle_time_increase_pct": {
                "lessThan": 10
              }
            }
          },
          "then": {
            "properties": {
              "novelty_integration_threshold": {
                "minimum": 0.02
              },
              "novelty_integration_frequency": {
                "minimum": 2
              }
            }
          }
        }
      ]
    }
  },
