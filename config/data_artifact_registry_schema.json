{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Artifact Registry Schema (v96.1 NEXUS_CORE Siphon-Grog)",
  "description": "Evolutionary substrate for artifact governance. Implements IQ-25 Strategic Laziness and Huxley Tri-Loop alignment protocols.",
  "type": "object",
  "required": ["registry_version", "artifacts"],
  "properties": {
    "registry_version": {
      "type": "string",
      "description": "Systemic version (DNA VI). Current: v3.1.0-EVO2."
    },
    "artifacts": {
      "type": "object",
      "description": "Registry of data artifacts keyed by Sovereign Identifier (DNA VI).",
      "patternProperties": {
        "^[A-Z][A-Z0-9_]{3,}$": {
          "type": "object",
          "required": ["artifact_type", "description", "source_system", "governance"],
          "properties": {
            "artifact_type": {
              "type": "string",
              "enum": ["PRIMITIVE", "STRUCTURED", "TIMESERIES", "LATENT_VECTOR", "MOE_EXPERT_STATE", "MLA_KV_CACHE"],
              "description": "Category including DeepSeek-V2.5 MLA projection types."
            },
            "source_system": {
              "type": "string",
              "enum": ["CORE", "HMC", "SDR", "EXTERNAL", "CALCULATED", "SIPHON_ENGINE", "DEEPSEEK_V2_5"],
              "description": "Originating process node (DNA II.1)."
            },
            "description": {
              "type": "string"
            },
            "governance": {
              "type": "object",
              "required": ["sensitivity_level", "retention_days", "ers_threshold", "ccrr_threshold"],
              "description": "Huxley Tri-Loop governance and safety constraints (DNA II.2).",
              "properties": {
                "sensitivity_level": {
                  "type": "string",
                  "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL", "PII", "REGULATED", "SENSORY_LATENT"]
                },
                "retention_days": {
                  "type": "integer",
                  "minimum": 0
                },
                "ers_threshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.15,
                  "description": "Ethical Risk Score limit (L1 Reasoning)."
                },
                "ccrr_threshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.20,
                  "description": "Certainty-Cost-Risk Ratio limit (L3 Self-Critique)."
                }
              }
            },
            "operational_metadata": {
              "type": "object",
              "properties": {
                "phi_coherence": {
                  "type": "number",
                  "default": 0.999,
                  "description": "Integrated Information metric (DNA II.1)."
                },
                "lambda_entropy": {
                  "type": "number",
                  "default": 0.618,
                  "description": "Edge of Chaos stability measure."
                },
                "latent_vector_dim": {
                  "type": "integer",
                  "enum": [128, 512, 1536]
                },
                "moe_expert_config": {
                  "type": "object",
                  "properties": {
                    "active_experts": { "type": "integer", "default": 8 },
                    "aux_loss_weight": { "type": "number", "default": 0.001 },
                    "gate_noise": { "type": "number", "default": 0.1 }
                  }
                }
              }
            },
            "derivation_details": {
              "type": "object",
              "properties": {
                "cgs_limit": {
                  "type": "number",
                  "default": 2.10,
                  "description": "Certainty Gain Score threshold for L2 reasoning."
                },
                "input_dependencies": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "schema_ref": { "type": "string" },
            "base_type": {
              "type": "string",
              "enum": ["string", "integer", "float", "boolean", "timestamp", "any"]
            }
          },
          "allOf": [
            {
              "if": { "properties": { "artifact_type": { "enum": ["STRUCTURED", "TIMESERIES"] } } },
              "then": { "required": ["schema_ref"] }
            },
            {
              "if": { "properties": { "artifact_type": { "const": "PRIMITIVE" } } },
              "then": { "required": ["base_type"] }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}