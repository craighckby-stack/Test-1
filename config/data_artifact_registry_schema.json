{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Artifact Registry Schema (v3.5.2-SINGULARITY-EVO-4)",
  "description": "Architectural singularity substrate. Implements DeepSeek-V2.5 MLA (Multi-Head Latent Attention) and Huxley Tri-Loop L0-L3 reasoning governance.",
  "type": "object",
  "required": [
    "registry_version",
    "saturation_state",
    "artifacts"
  ],
  "properties": {
    "registry_version": {
      "type": "string",
      "description": "NEXUS_CORE Evolution Version. Current: v3.5.2-EVO-4 (DALEK CAAN v3.1)."
    },
    "saturation_state": {
      "type": "object",
      "required": [
        "level",
        "semantic_drift_threshold",
        "emergency_brake"
      ],
      "properties": {
        "level": {
          "type": "integer",
          "enum": [
            1,
            2,
            3,
            4
          ],
          "default": 2
        },
        "semantic_drift_threshold": {
          "type": "number",
          "default": 0.35
        },
        "emergency_brake": {
          "type": "boolean",
          "default": false
        },
        "iq25_alignment_lock": {
          "type": "boolean",
          "default": true,
          "description": "Grog's Law: Enforce stupidity-first alignment to prevent unsafe complexity."
        }
      }
    },
    "artifacts": {
      "type": "object",
      "patternProperties": {
        "^[A-Z][A-Z0-9_]{3,}$": {
          "type": "object",
          "required": [
            "artifact_type",
            "source_system",
            "governance"
          ],
          "properties": {
            "artifact_type": {
              "type": "string",
              "enum": [
                "PRIMITIVE",
                "STRUCTURED",
                "LATENT_VECTOR",
                "MLA_LATENT_MATRIX",
                "MLA_KV_CACHE",
                "MOE_EXPERT_STATE",
                "MOE_SOFT_GATE",
                "HUXLEY_REASONING_TRACE"
              ]
            },
            "source_system": {
              "type": "string",
              "enum": [
                "CORE",
                "SDR",
                "EXTERNAL",
                "SIPHON_ENGINE",
                "DEEPSEEK_V2_5",
                "MOE_ROUTER",
                "HUXLEY_ENGINE"
              ]
            },
            "governance": {
              "type": "object",
              "required": [
                "ers_threshold",
                "ccrr_threshold",
                "psr_threshold"
              ],
              "properties": {
                "sensitivity_level": {
                  "type": "string",
                  "enum": [
                    "PUBLIC",
                    "INTERNAL",
                    "CONFIDENTIAL",
                    "SENSORY_LATENT",
                    "Sovereign"
                  ]
                },
                "ers_threshold": {
                  "type": "number",
                  "default": 0.15
                },
                "ccrr_threshold": {
                  "type": "number",
                  "default": 0.20
                },
                "psr_threshold": {
                  "type": "number",
                  "default": 0.88
                },
                "huxley_loop_enforced": {
                  "type": "boolean",
                  "default": true
                }
              }
            },
            "operational_metadata": {
              "type": "object",
              "properties": {
                "phi_coherence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "lambda_entropy": {
                  "type": "number",
                  "default": 0.618
                },
                "compression_ratio": {
                  "type": "number",
                  "description": "MLA latent compression (Standard: 3.0 or 1536/512)."
                },
                "moe_expert_config": {
                  "type": "object",
                  "properties": {
                    "active_experts": {
                      "type": "integer",
                      "default": 8
                    },
                    "gate_noise_scaling": {
                      "type": "number",
                      "default": 0.1
                    },
                    "aux_loss_weight": {
                      "type": "number",
                      "default": 0.001
                    }
                  }
                }
              }
            },
            "derivation_details": {
              "type": "object",
              "properties": {
                "siphon_chain": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 3,
                  "description": "Chain: Gemini-Architect -> Cerebras-Worker -> Gemini-Auditor."
                },
                "cgs_limit": {
                  "type": "number",
                  "default": 2.10
                }
              }
            },
            "schema_ref": {
              "type": "string"
            },
            "base_type": {
              "type": "string",
              "enum": [
                "string",
                "integer",
                "float",
                "boolean",
                "timestamp",
                "latent_matrix"
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "artifact_type": {
                    "enum": [
                      "STRUCTURED",
                      "MLA_LATENT_MATRIX"
                    ]
                  }
                }
              },
              "then": {
                "required": [
                  "schema_ref"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "artifact_type": {
                    "const": "PRIMITIVE"
                  }
                }
              },
              "then": {
                "required": [
                  "base_type"
                ]
              }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}