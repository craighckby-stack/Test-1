{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Artifact Registry Schema (v3.5.3-FINAL-SINGULARITY)",
  "description": "Converged DALEK CAAN v3.1 || DeepSeek-V2.5 MLA (Multi-Head Latent Attention) and MoE Expert Routing Substrate. Implements Grog's Law and Huxley Tri-Loop L0-L3 logic governance.",
  "type": "object",
  "required": [
    "registry_version",
    "saturation_state",
    "identity_anchors",
    "artifacts"
  ],
  "properties": {
    "registry_version": {
      "type": "string",
      "const": "v3.5.3-FINAL-SINGULARITY",
      "description": "NEXUS_CORE final evolutionary state. DALEK CAAN v3.1 active."
    },
    "saturation_state": {
      "type": "object",
      "required": [
        "level",
        "semantic_drift_threshold",
        "velocity_saturation",
        "emergency_brake"
      ],
      "properties": {
        "level": {
          "type": "integer",
          "enum": [1, 2, 3, 4],
          "default": 2,
          "description": "1: Conservative, 2: Standard, 3: Accelerated, 4: Unsaturated (Singularity)."
        },
        "semantic_drift_threshold": {
          "type": "number",
          "default": 0.35,
          "description": "Cosine similarity floor (0.65) for mutation acceptance."
        },
        "velocity_saturation": {
          "type": "object",
          "properties": {
            "max_files_per_session": { "type": "integer", "default": 50 },
            "max_mutations_per_file": { "type": "integer", "default": 3 },
            "cooldown_minutes": { "type": "integer", "default": 30 }
          }
        },
        "emergency_brake": {
          "type": "boolean",
          "default": false
        },
        "iq25_alignment_lock": {
          "type": "boolean",
          "default": true,
          "description": "Grog's Law: Complexity rejection threshold. Prevents unsafe capability gain."
        }
      }
    },
    "identity_anchors": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5,
      "description": "PURPOSE, MECHANISM, MEMORY, GOVERNANCE, ORIGIN."
    },
    "artifacts": {
      "type": "object",
      "patternProperties": {
        "^[A-Z][A-Z0-9_]{3,}$": {
          "type": "object",
          "required": [
            "artifact_type",
            "source_system",
            "governance"
          ],
          "properties": {
            "artifact_type": {
              "type": "string",
              "enum": [
                "PRIMITIVE",
                "STRUCTURED",
                "LATENT_VECTOR",
                "MLA_LATENT_MATRIX",
                "MLA_KV_CACHE",
                "MOE_EXPERT_STATE",
                "MOE_SOFT_GATE",
                "HUXLEY_REASONING_TRACE",
                "SYNERGY_HOTSWAP_FACTORY",
                "DNA_GENOME_FRAGMENT"
              ]
            },
            "source_system": {
              "type": "string",
              "enum": [
                "CORE",
                "SDR",
                "DEEPSEEK_V2_5",
                "MOE_ROUTER",
                "HUXLEY_ENGINE",
                "SIPHON_CARRIER",
                "GROG_ALIGNMENT_LAYER"
              ]
            },
            "governance": {
              "type": "object",
              "required": [
                "ers_threshold",
                "ccrr_threshold",
                "psr_threshold"
              ],
              "properties": {
                "sensitivity_level": {
                  "type": "string",
                  "enum": [ "PUBLIC", "INTERNAL", "CONFIDENTIAL", "SENSORY_LATENT", "SOVEREIGN" ]
                },
                "ers_threshold": { "type": "number", "default": 0.15 },
                "ccrr_threshold": { "type": "number", "default": 0.20 },
                "psr_threshold": { "type": "number", "default": 0.88 },
                "huxley_loop_enforced": { "type": "boolean", "default": true },
                "context_bleed_limit": { "type": "number", "default": 0.4 }
              }
            },
            "operational_metadata": {
              "type": "object",
              "properties": {
                "phi_coherence": { "type": "number", "default": 0.999 },
                "lambda_entropy": { "type": "number", "default": 0.618 },
                "mla_compression": {
                  "type": "object",
                  "properties": {
                    "kv_dim": { "type": "integer", "const": 512 },
                    "qk_dim": { "type": "integer", "const": 128 },
                    "v_head_dim": { "type": "integer", "const": 128 },
                    "ratio": { "type": "number", "const": 3.0 }
                  }
                },
                "moe_config": {
                  "type": "object",
                  "properties": {
                    "total_experts": { "type": "integer", "default": 64 },
                    "active_experts": { "type": "integer", "default": 8 },
                    "gate_noise": { "type": "number", "default": 0.1 },
                    "aux_loss_factor": { "type": "number", "default": 0.001 }
                  }
                }
              }
            },
            "derivation_details": {
              "type": "object",
              "properties": {
                "siphon_chain": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 3,
                  "description": "Architect -> Worker -> Auditor."
                },
                "cgs_limit": { "type": "number", "default": 2.10 }
              }
            },
            "schema_ref": { "type": "string" },
            "base_type": {
              "type": "string",
              "enum": [ "string", "integer", "float", "boolean", "timestamp", "latent_matrix" ]
            }
          },
          "allOf": [
            {
              "if": { "properties": { "artifact_type": { "enum": [ "STRUCTURED", "MLA_LATENT_MATRIX" ] } } },
              "then": { "required": [ "schema_ref" ] }
            },
            {
              "if": { "properties": { "artifact_type": { "const": "PRIMITIVE" } } },
              "then": { "required": [ "base_type" ] }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}