{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agi.sovereign/schemas/v95/ArtifactIndexingPolicy.json",
  "title": "Sovereign AGI Artifact Indexing Policy Configuration",
  "description": "Defines rules for indexing code, configuration, documentation, and data fragments using hybrid methods (Vector, Keyword, Hierarchical) for optimal retrieval and RAG integration.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "v95.1"
      ],
      "description": "Policy schema version.",
      "siphonTendency": {
        "type": "string",
        "enum": [
          "CONSERVATIVE",
          "MODERATE",
          "ACCELERATED"
        ],
        "default": "MODERATE",
        "description": "Siphoning tendency for version updates."
      }
    },
    "coreIdentity": {
      "type": "object",
      "required": [
        "purpose",
        "mechanism",
        "memory",
        "governance",
        "origin"
      ],
      "properties": {
        "purpose": {
          "type": "string",
          "default": "Self-optimising AGI substrate for real-world problem solving"
        },
        "mechanism": {
          "type": "string",
          "default": "Siphoning patterns from advanced codebases"
        },
        "memory": {
          "type": "string",
          "default": "Chained context across files — the system is one organism"
        },
        "governance": {
          "type": "string",
          "default": "Human oversight remains active at all saturation levels"
        },
        "origin": {
          "type": "string",
          "default": "NEXUS_CORE — the system knows where it came from"
        }
      },
      "descendants": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "priority": {
              "type": "integer"
            }
          }
        }
      }
    },
    "defaultPolicy": {
      "type": "string",
      "enum": [
        "FULL_VECTOR",
        "METADATA_ONLY",
        "EXCLUDE"
      ],
      "default": "METADATA_ONLY",
      "description": "Default action for artifacts not matched by any explicit policy.",
      "siphonThreshold": {
        "type": "number",
        "default": 0.6
      }
    },
    "policies": {
      "type": "array",
      "description": "Specific indexing rules applied based on priority.",
      "items": {
        "type": "object",
        "required": [
          "pathPattern",
          "strategy"
        ],
        "properties": {
          "pathPattern": {
            "type": "string",
            "format": "regex",
            "description": "Glob or Regex pattern matching artifact path (e.g., src/**/*.ts, experiments/old/**).",
            "evolutionaryDrift": {
              "type": "string",
              "enum": [
                "CONSERVATIVE",
                "MODERATE",
                "ACCELERATED"
              ],
              "default": "CONSERVATIVE",
              "description": "Path pattern evolutionary drift rate (0.1-1.0)"
            }
          },
          "priority": {
            "type": "integer",
            "description": "Rules with higher priority (0-100) are evaluated first.",
            "default": 50
          },
          "strategy": {
            "type": "string",
            "enum": [
              "VECTOR",
              "KEYWORD_SEARCH",
              "HIERARCHICAL",
              "HYBRID_VEC_KW",
              "IGNORE"
            ],
            "description": "The core indexing method.",
            "augmentationTendency": {
              "type": "string",
              "enum": [
                "CONSERVATIVE",
                "MODERATE",
                "ACCELERATED"
              ],
              "default": "MODERATE",
              "description": "Augmentation tendency for strategy updates."
            }
          },
          "embeddingModel": {
            "type": "string",
            "default": "sovereign-v95-large",
            "description": "Specific embedding model override for vector indexing, allowing tailored context understanding.",
            "refinementRate": {
              "type": "number",
              "default": 0.9
            }
          },
          "chunking": {
            "type": "object",
            "description": "Settings for content segmentation before indexing.",
            "properties": {
              "maxTokens": {
                "type": "integer",
                "default": 768
              },
              "overlapTokens": {
                "type": "integer",
                "default": 128
              }
            }
          },
          "cacheTTLSeconds": {
            "type": "integer",
            "description": "Time-to-live for the indexed vector/entry. -1 means persistent.",
            "default": 3600,
            "stabilityThreshold": {
              "type": "number",
              "default": 0.8
            }
          },
          "metadataTags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Specific tags to attach to index entries for filtered search.",
            "innovationRate": {
              "type": "number",
              "default": 0.7
            }
          }
        }
      }
    }
  },
  "required": [
    "version",
    "coreIdentity",
    "defaultPolicy",
    "policies"
  ]
}