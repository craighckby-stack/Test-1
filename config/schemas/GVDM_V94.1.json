{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agi.system/GVDM_V94.5.schema.json",
  "title": "Governance/Veto/Dependency Manifest Schema V94.5",
  "type": "object",
  "properties": {
    "manifestId": {
      "type": "string",
      "format": "uuid",
      "description": "A unique identifier for auditing purposes."
    },
    "manifestVersion": {
      "type": "string",
      "pattern": "^GVDM-V(\\d+\\.(\\d+\\.(\\d+)?(\\.\\d+)?))"
    },
    "certifiedTime": {
      "type": "string",
      "format": "date-time",
      "properties": {
        "validUntil": {
          "type": "string",
          "format": "date-time",
          "description": "The time this manifest should be considered deprecated or requires re-certification.",
          "properties": {
            "dependencyIntegrityChecklist": {
              "type": "array",
              "items": {
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The name of the dependency."
                  },
                  "hash": {
                    "type": "string",
                    "pattern": "^sha256:[a-fA-F0-9]{32,64}$",
                    "description": "The hash of the dependency."
                  },
                  "minimumVersion": {
                    "type": "string",
                    "description": "The minimum required version of the dependency."
                  },
                  "maxVersion": {
                    "type": "string",
                    "description": "The maximum allowed version of the dependency."
                  }
                }
              }
            },
            "dependencyIntegrityThreshold": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "A dynamic value for tracking dependency integrity"
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": {
          "type": "string",
          "description": "The author of the manifest."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the manifest was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the manifest was last updated."
        },
        "updatedBy": {
          "type": "string",
          "description": "The author who last updated the manifest."
        },
        "hashFunctions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Hash function name."
              },
              "version": {
                "type": "string",
                "description": "Hash function version."
              }
            }
          }
        }
      },
      "required": ["author", "createdAt", "updatedAt"],
      "properties": {
        "authorNotes": {
          "type": "string",
          "description": "A note from the author for context to validators and readers. Supports long-form text."
        }
      }
    },
    "validatedPolicyIntegrity": {
      "type": "boolean",
      "description": "A flag indicating whether the policy integrity has been validated by a governance authority."
    },
    "certifiedManifests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["acronym", "version"],
        "properties": {
          "acronym": {
            "type": "string",
            "description": "The acronym of the certified manifest."
          },
          "version": {
            "type": "string",
            "description": "The version of the certified manifest."
          },
          "policyIntegrityThreshold": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "The threshold for policy integrity, representing the likelihood of policy violations."
          }
        }
      }
    }
  },
  "required": [
    "manifestId",
    "manifestVersion",
    "certifiedTime",
    "dependencyIntegrityChecklist",
    "validatedPolicyIntegrity",
    "certifiedManifests",
    "metadata"
  ],
  "additionalProperties": false,
  "links": {
    "self": {
      "href": "https://schemas.agi.system/GVDM_V94.5.schema.json"
    },
    "previous": {
      "href": "https://schemas.agi.system/GVDM_V94.4.schema.json"
    },
    "next": {
      "href": "https://schemas.agi.system/GVDM_V94.6.schema.json"
    }
  }
}