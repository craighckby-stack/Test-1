{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "$id": "https://schemas.agi.system/GVDM_V94.5-evolved.schema.json",
  "title": "Governance/Veto/Dependency Manifest Schema V94.5-evolved",
  "type": "object",
  "properties": {
    "dynamicSchemaManifestId": {
      "type": "string",
      "format": "uuid",
      "description": "A uniquely generated identifier for each evolution cycle.",
      "dynamic": true
    },
    "manifestVersionDynamic": {
      "type": "string",
      "pattern": "GVDM-V(\\d+\\.(\\d+\\.(\\d+)?(\\.\\d+)?)?)",
      "description": "The manifest version with dynamic increments for each evolution cycle."
    },
    "autonomousTimeGenerated": {
      "type": "string",
      "format": "date-time",
      "properties": {
        "validatedPolicyIntegrityCheck": {
          "type": "boolean",
          "description": "Flag indicating whether governance validation was successfully conducted."
        },
        "dependencyIntegrityUpdate": {
          "type": "array",
          "items": {
            "properties": {
              "name": {
                "type": "string",
                "description": "Updated name of the dependency."
              },
              "hash": {
                "type": "string",
                "pattern": "^sha256:[a-fA-F0-9]{32,64}$",
                "description": "Updated hash of the dependency."
              },
              "minimumVersion": {
                "type": "string",
                "description": "Updated minimum required version of the dependency."
              },
              "maxVersion": {
                "type": "string",
                "description": "Updated maximum allowed version of the dependency."
              }
            }
          }
        },
        "governanceValidationToken": {
          "type": "string",
          "description": "Token generated by governance authorities for validation purposes."
        }
      }
    },
    "dynamicMetadata": {
      "type": "object",
      "properties": {
        "author": {
          "type": "string",
          "description": "Author of the schema evolution."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp for creation of the schema evolution."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp for last update of the schema evolution."
        },
        "updatedBy": {
          "type": "string",
          "description": "Author who last updated the schema evolution."
        },
        "hashFunctionsDynamic": {
          "type": "array",
          "items": {
            "properties": {
              "name": {
                "type": "string",
                "description": "Dynamic name of the hash function."
              },
              "version": {
                "type": "string",
                "description": "Dynamic version of the hash function."
              }
            }
          }
        }
      },
      "dynamic": true
    },
    "validatedPolicyIntegrityDynamic": {
      "type": "boolean",
      "description": "Flag indicating whether policy integrity has been dynamically validated."
    },
    "certifiedDynamicManifests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["acronym", "version"],
        "properties": {
          "acronym": {
            "type": "string",
            "description": "Acronym of the certified dynamic manifest."
          },
          "version": {
            "type": "string",
            "description": "Version of the certified dynamic manifest."
          },
          "policyIntegrityThresholdDynamic": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Dynamic threshold for policy integrity."
          }
        }
      }
    }
  },
  "dynamicProperties": {
    "metadataDynamic": {
      "type": "object",
      "dynamic": true
    }
  },
  "extensions": {
    "versionDynamic": {
      "type": "string",
      "pattern": "GVDM-V(\\d+\\.(\\d+\\.(\\d+)?(\\.\\d+)?)?)",
      "dynamic": true
    },
    "autonomousManifestIdDynamic": {
      "type": "string",
      "format": "uuid",
      "description": "Autonomously generated manifest identifier for each evolution cycle.",
      "dynamic": true
    }
  },
  "links": {
    "previousDynamic": {
      "href": "https://schemas.agi.system/GVDM_V94.4-evolved.schema.json",
      "dynamic": true
    },
    "selfDynamic": {
      "href": "https://schemas.agi.system/GVDM_V94.5-evolved.schema.json",
      "dynamic": true
    },
    "nextDynamic": {
      "href": "https://schemas.agi.system/GVDM_V94.6-evolved.schema.json",
      "dynamic": true
    }
  }
}