{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "config/schemas/pipeline_config_meta.json",
  "title": "Sovereign AGI Pipeline Configuration Dynamic-Adaptive Meta-Schema",
  "$recursiveRequired": true,
  "type": "object",
  "properties": {
    "dynamic_version": {
      "type": "string",
      "description": "Auto-generated semantic versioning of the configuration structure.",
      "dependencies": {
        "mutation_timestamp": {
          "type": "integer",
          "format": "timestamp",
          "dynamic": true,
          "description": "Timestamp indicating when this configuration was dynamically generated."
        }
      }
    },
    "pipeline_id": {"type": "string"},
    "config_description": {
      "type": "string",
      "description": "Metadata description of the current pipeline configuration.",
      "dependencies": {
        "mutation_context": {
          "type": "string",
          "format": "uri-reference",
          "dynamic": true,
          "description": "Dynamic reference indicating where this configuration context was generated."
        }
      }
    },
    "schema_reference": {
      "type": "object",
      "properties": {
        "schema_uri": {
          "type": "string",
          "format": "uri-reference"
        },
        "schema_hash": {
          "type": "string",
          "format": "hash",
          "dynamic": true,
          "description": "Dynamically generated hash of the schema for validation purposes."
        },
        "last_update": {
          "type": "integer",
          "format": "timestamp",
          "dynamic": true,
          "description": "Timestamp indicating when the schema was last updated."
        }
      }
    },
    "runtime_profile": {
      "type": "object",
      "properties": {
        "runtime_type": {
          "type": "string",
          "description": "Runtime environment profile for the pipeline (e.g. Kubernetes, Docker, etc.)."
        },
        "container_profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "container_id": {
                "type": "string"
              },
              "image_reference": {
                "type": "string",
                "format": "docker-reference"
              },
              "environment_variables": {
                "type": "object",
                "properties": {
                  "ENV_VAR_1": {
                    "type": "string",
                    "description": "Environment variable for container execution."
                  },
                  "ENV_VAR_2": {
                    "type": "string",
                    "description": "Environment variable for container execution."
                  }
                }
              }
            }
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "$ref": "#/dynamic_stages"
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "health_check": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string",
              "format": "uri-reference"
            },
            "interval": {
              "type": "integer",
              "minimum": 1,
              "dynamic": true,
              "description": "Dynamically set interval for health checks in seconds."
            },
            "timeout": {
              "type": "integer",
              "minimum": 1,
              "dynamic": true,
              "description": "Dynamically set timeout for health checks in seconds."
            }
          }
        },
        "metrics_export": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string",
              "format": "uri-reference"
            },
            "interval": {
              "type": "integer",
              "minimum": 1,
              "dynamic": true,
              "description": "Dynamically set interval for metric export in seconds."
            }
          }
        }
      }
    },
    "certifiedDynamicManifests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "acronym": {
            "type": "string",
            "description": "Acronym of the certified dynamic manifest."
          },
          "version": {
            "type": "string",
            "description": "Version of the certified dynamic manifest."
          },
          "policyIntegrityThresholdDynamic": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "incremental": true,
            "description": "Dynamically updated threshold for policy integrity.",
            "dynamic": true
          },
          "securityProfileDynamic": {
            "type": "object",
            "properties": {
              "sslEnabledDynamic": {
                "type": "boolean",
                "dynamic": true,
                "description": "Flag indicating whether SSL/TLS is enabled for IPSM communications."
              },
              "corsEnabledDynamic": {
                "type": "boolean",
                "dynamic": true,
                "description": "Flag indicating whether CORS is enabled for IPSM web services."
              },
              "authRequiredDynamic": {
                "type": "boolean",
                "dynamic": true,
                "description": "Flag indicating whether authentication is required for IPSM services."
              }
            },
            "required": ["sslEnabledDynamic", "corsEnabledDynamic", "authRequiredDynamic"]
          }
        }
      },
      "dynamic": true,
      "description": "List of certified dynamic manifests with current integrity status."
    },
    "siphoningMetricsAutonomous": {
      "type": "object",
      "properties": {
        "mutationCountDynamic": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000,
          "incremental": true,
          "description": "Autonomously updated total count of IPSM schema mutations.",
          "dynamic": true
        },
        "schemaValidationTimeDynamic": {
          "type": "number",
          "format": "float",
          "minimum": 0,
          "maximum": 1000,
          "dynamic": true,
          "description": "Dynamically updated IPSM schema validation time in milliseconds."
        },
        "mutationTimePercentageDynamic": {
          "type": "number",
          "format": "float",
          "minimum": 0,
          "maximum": 100,
          "dynamic": true,
          "description": "Autonomously updated percentage of total IPSM schema mutation time."
        }
      },
      "required": ["mutationCountDynamic"],
      "dynamic": true
    }
  },
  "dynamic_stages": {
    "title": "Adaptive Stage Schema",
    "type": "object",
    "properties": {
      "stage_id": {"type": "string"},
      "handler_class": {"type": "string"},
      "dependencies": {"type": "array"},
      "condition_trigger": {
        "type": "string",
        "enum": ["SUCCESS", "FAILURE", "ALWAYS"],
        "dynamic": true
      },
      "parameters": {"type": "object"},
      "chain_context": {
        "type": "object",
        "properties": {
          "previous_stage_id": {"type": "string"},
          "parent_stage_id": {"type": "string"}
        }
      }
    },
    "required": ["stage_id", "handler_class", "dependencies", "condition_trigger"],
    "dynamic_properties": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "property_name": {"type": "string"},
          "value": {"type": "any"},
          "timestamp": {
            "type": "integer",
            "format": "timestamp",
            "dynamic": true,
            "description": "Timestamp of when this property was dynamically generated."
          }
        }
      }
    }
  },
  "links": {
    "previousDynamic": {
      "href": "https://schemas.agi.system/IPSM_V94.4-evolved.schema.json",
      "dynamic": true,
      "description": "Autonomous link to previous IPSM runtime state schema.",
      "dependencies": {
        "previousSchemaHashDynamic": {
          "type": "string",
          "format": "hash",
          "dynamic": true,
          "description": "Hash of the previous IPSM schema for validation purposes."
        }
      }
    },
    "selfDynamic": {
      "href": "https://schemas.agi.system/IPSM_V94.5-evolved.schema.json",
      "dynamic": true,
      "description": "Autonomous link to current IPSM runtime state schema."
    },
    "nextDynamic": {
      "href": "https://schemas.agi.system/IPSM_V94.6-evolved.schema.json",
      "dynamic": true,
      "description": "Autonomous link to next IPSM runtime state schema."
    }
  },
  "required": ["dynamic_version", "pipeline_id", "stages", "runtime_profile"]
}