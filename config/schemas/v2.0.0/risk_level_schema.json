{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agi.sovereign/schemas/v2.1.1/risk_level_schema.json",
  "title": "ATM Risk Level Configuration Schema | v2.1.1",
  "type": "object",
  "properties": {
    "levels": {
      "type": "object",
      "description": "Hybrid Map of risk levels indexed by their unique ID.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "severity_score": {"type": "integer", "minimum": 1, "maximum": 999, "enum": [5, 10, 20, 50, 100]},
          "impact": {"type": "string", "const": ["low", "medium", "high"]},
          "enforcement_type": {
            "type": "string",
            "enum": ["HARD_HALT", "THROTTLE_50", "RESOURCE_REALLOCATE", "OBSERVE", "LOG_ONLY"]
          },
          "required_action": {"type": "string"},
          "trust_penalty_multiplier": {"type": "number", "minimum": 0.0, "maximum": 10.0, "dynamic": true},
          "notification_groups": {"type": "array", "items": {"type": "string"}},
          "auto_correct_factor": {"type": "number", "minimum": 0.0, "maximum": 100.0},
          "action_ttl_s": {"type": ["integer", "null"], "description": "Time to live for required action in seconds. 0 for immediate."}
        },
        "required": ["severity_score", "impact", "enforcement_type", "required_action"]
      }
    },
    "default_risk_level": {"type": "string"},
    "custom_enforcement_configs": {
      "type": "object",
      "properties": {
        "level_bypass_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 100.0
        }
      },
      "required": ["level_bypass_threshold"]
    },
    "dynamic_metadata": {"type": "object"}
  },
  "required": ["levels", "default_risk_level"],
  "dynamic_properties": {
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "metadata_prop": {"type": "string"},
        "timestamp": {
          "type": "integer",
          "format": "timestamp",
          "dynamic": true
        }
      }
    }
  },
  "saturation_version": "v2.0.0",
  "saturation_level": {
    "type": "string",
    "enum": ["CONSERVATIVE", "STANDARD", "ACCELERATED", "UNSATURATED"]
  }
}