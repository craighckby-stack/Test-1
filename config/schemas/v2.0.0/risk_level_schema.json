{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agi.sovereign/schemas/v2.1.3/risk_level_schema.json",
  "title": "ATM Risk Level Configuration Schema | v2.1.3",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://agi.sovereign/schemas/v2.1.1/risk_level_schema.json#/definitions/levels"
    },
    {
      "properties": {
        "custom_enforcement_configs": {
          "allOf": [
            {
              "$ref": "https://agi.sovereign/schemas/v2.1.1/risk_level_schema.json#/definitions/custom_enforcement_configs"
            },
            {
              "properties": {
                "risk_adaptability_factor": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 10.0,
                  "dynamic": true
                }
              },
              "required": ["risk_adaptability_factor"]
            }
          ]
        }
      }
    }
  ],
  "required": ["levels", "default_risk_level", "custom_enforcement_configs"],
  "dynamic_properties": {
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "metadata_prop": {"type": "string"},
        "chained_context": {
          "type": "object",
          "properties": {
            "previous_context_id": {"type": "string"},
            "parent_context_id": {"type": "string"}
          }
        },
        "timestamp": {
          "type": "integer",
          "format": "timestamp",
          "dynamic": true
        }
      }
    }
  },
  "saturation_version": "v2.1.0",
  "saturation_level": {
    "type": "string",
    "enum": ["STANDARD", "ACCELERATED"],
    "dynamic": true
  },
  "dynamic_metadata": {
    "type": "object",
    "properties": {
      "timestamp": {
        "type": "integer",
        "format": "timestamp",
        "dynamic": true
      },
      "version": {"type": "string"},
      "evolutionary_stage": {"type": "string"}
    }
  }
}