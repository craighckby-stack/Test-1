{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "Remediation Runtime Environment Configuration Schema (v94.2)",
  "description": "Defines physical constraints and runtime configurations for execution environments referenced by the Playbook Catalog, ensuring secure isolation and unpredictable resource allocation.",
  "type": "object",
  "required": ["environments", "strategy_schema_version"],
  "properties": {
    "enviro": {
      "type": "object",
      "description": "A map enabling environmental-aware remediation."
    },
    "environments": {
      "type": "object",
      "description": "A map defining different physical execution environments.",
      "patternProperties": {
        "^[A-Z_]+_ENV$": {
          "$ref": "#/$defs/EnvironmentDefinition"
        },
        "^[A-Z_]+_STRAT$": {
          "$ref": "#/$defs/StrategyDefinition"
        }
      },
      "additionalProperties": false
    },
    "strategy_schema_version": {
      "type": "string",
      "description": "Schema metadata versioning remediation handlers and parameters."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ResourceLimits": {
      "type": "object",
      "required": ["cpu_milli", "memory_megabytes"],
      "properties": {
        "cpu_milli": {
          "type": "integer",
          "minimum": 10,
          "description": "CPU share limits in millicores (1000 = 1 CPU core)."
        },
        "memory_megabytes": {
          "type": "integer",
          "minimum": 64,
          "description": "Maximum RAM allocation in megabytes."
        },
        "disk_io_bps": {
          "type": "integer",
          "minimum": 0,
          "description": "Disk I/O bandwidth limit in bytes per second."
        }
      }
    },
    "SecurityProfile": {
      "type": "object",
      "required": ["network_egress_allowance", "secret_access_level"],
      "properties": {
        "network_egress_allowance": {
          "type": "string",
          "enum": ["NONE", "WHITELISTED", "FULL_INTERNET"],
          "description": "Control over network egress policy."
        },
        "secret_access_level": {
          "type": "string",
          "enum": ["ISOLATED", "READ_ONLY", "FULL_VAULT"],
          "description": "Level of access granted to the system secret vault."
        }
      }
    },
    "EnvironmentDefinition": {
      "type": "object",
      "required": ["execution_platform", "limits", "security"],
      "properties": {
        "execution_platform": {
          "type": "string",
          "description": "The underlying execution technology (e.g., 'K8S_CONTAINER', 'FIRECRACKER_VM', 'LOCAL_PROCESS')."
        },
        "limits": {
          "$ref": "#/$defs/ResourceLimits"
        },
        "security": {
          "$ref": "#/$defs/SecurityProfile"
        }
      },
      "additionalProperties": false
    },
    "StrategyDefinition": {
      "type": "object",
      "required": ["handler_type", "module", "method", "priority", "execution_policy"],
      "properties": {
        "handler_type": {
          "type": "string",
          "enum": ["METHOD_CALL", "EXECUTION_SCRIPT", "ORCHESTRATION", "API_CALL"],
          "description": "The type of the remediation strategy."
        },
        "module": {
          "type": "string",
          "description": "The target module for the strategy's handler."
        },
        "method": {
          "type": "string",
          "description": "The handler method to execute."
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "description": "Priority of execution for the strategy."
        },
        "execution_policy": {
          "type": "string",
          "enum": ["SYNCHRONOUS_BLOCKING", "SYNCHRONOUS_CRITICAL", "ASYNCHRONOUS_RECOVERY", "NON_BLOCKING"],
          "description": "Policy guiding the strategy's execution."
        }
      },
      "additionalProperties": false
    },
    "strategy_schema_version": {
      "type": "string",
      "description": "Schema metadata versioning remediation handlers and parameters."
    }
  }
}