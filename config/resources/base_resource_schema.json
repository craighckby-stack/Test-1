{
  "schemaId": "RES_SCH_V3",
  "resourceTypes": {
    "KubeCluster": {
      "requiredFields": ["provider", "region", "minNodes"],
      "validationRules": {
        "minNodes": "int_gt_0",
        "maxNodes": "int_lt_node_capacity"
      },
      "additionalFields": [
        {
          "name": "nodeCapacity",
          "type": "int",
          "description": "Maximum number of nodes allowed"
        },
        {
          "name": "scalingPolicy",
          "type": "str",
          "description": "Scaling strategy for the cluster"
        },
        {
          "name": "predictiveModel",
          "type": "obj",
          "description": "Predictive model configuration"
        }
      ]
    },
    "Postgres": {
      "requiredFields": ["endpoint", "port", "engineVersion"],
      "validationRules": {
        "engineVersion": "str_matches_pattern(^[1-9\\./]+$)"
      },
      "additionalFields": [
        {
          "name": "storageSize",
          "type": "int",
          "description": "Size of storage allocated to the Postgres instance"
        },
        {
          "name": "connectionOptions",
          "type": "obj",
          "description": "Postgres connection options"
        },
        {
          "name": "securitySettings",
          "type": "obj",
          "description": "Security settings for Postgres instance"
        }
      ]
    }
  },
  "metadata": {
    "description": "Defines the mandatory structure and validation for resource entries referenced by GODM, integrated with QoS and allocation strategies with predictive and security enhancements",
    "qosTierPrioritizationExtension": [
      {
        "newTier": "Tier0_Urgent",
        "newPriority": 150
      }
    ],
    "allocationStrategiesExtension": [
      {
        "newStrategy": "Predictive_Priority_SelfAdaptive",
        "newQueueType": "PriorityQueue",
        "newMachineLearningModel": "ANN_Resource_Predictor_V5"
      }
    ],
    "mlModels": {
      "LSTM_Demand_Predictor_V5": {
        "newFeatures": ["diskReadLatencyAvg", "cpuCores", "memoryFreePercent"],
        "trainingFrequencyHours": 4
      }
    },
    "sensitivityTolerancePercent": 2.5
  }
}