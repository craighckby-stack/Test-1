    "condition": "@environment.getProperty('nexus.simulation.enabled', 'true') == 'true'",
    "predictive_depth": "P4_EXECUTION_OUTCOME",
    "error_handler": "NexusTrajectoryExceptionHandler"
  },
  "dependency_graph": {
