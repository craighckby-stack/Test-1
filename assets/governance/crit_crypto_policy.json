      "policyAuditor": "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2",
      "securityEnforcer": "b9c8d7e6f5a4b3c2d1e0f9a8b7c6d5e4f3a2b1c0e9d8c7b6a5f4e3d2c1b0a9f",
      "observationRegistry": "d3f4e5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2"
    },
    "qualifier": "nexus-high-integrity-v3"
