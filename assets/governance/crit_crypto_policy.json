      "ConsensusSignatureValidator",
      "HhhComplianceInterceptor",
      "PolicyVolatilityInterceptor",
      "ContextualFluxBoundaryGuard",
      "SpringSecurityContextAdapter",
      "ReactiveBackpressureCoordinator"
    ],
    "pointcut_expression": "execution(* nexus.core.crypto.SiphonCrypter.decrypt*(..)) || @annotation(nexus.core.annotations.GatedSiphon) || @annotation(nexus.core.annotations.NexusSecureTransition)",
    "spel_validation": "@nexusMetricNexus.isStable() && #root.cryptographic_assertion_config.key_requirements.ECC_minimum_bits >= 384 && #root.calibration_metrics.TCF > 0.99 && !#root.telemetry_nexus_snapshot.integrity_gates.isEmpty()",
    "inheritance_resolver": {
