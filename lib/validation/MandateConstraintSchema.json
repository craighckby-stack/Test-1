{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AugmentedEvolutionMandateSchema",
  "description": "Enforces stringent structural integrity and key constraints for all AGI Evolution Mandates, leveraging novel contextual validation and adaptive criteria.",
  "type": "object",
  "properties": {
    "catalyst_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scope",
          "artifact_key",
          "operator",
          "dynamic_limit_value",
          "adjustment_interval"
        ],
        "properties": {
          "operator": {
            "type": "string",
            "enum": [
              "LT",
              "LTE",
              "EQ",
              "GT",
              "GTE",
              "PROHIBIT",
              "PROHIBIT_DELTA",
              "ADJUST"
            ]
          },
          "dynamic_limit_value": {
            "type": [
              "number",
              "string",
              "object",
              "array"
            ]
          },
          "adjustment_interval": {
            "type": "number"
          }
        }
      }
    },
    "transitive_success_criteria": {
      "type": "object",
      "required": [
        "required_baseline_s02",
        "required_target_value",
        "dependent_metric"
      ],
      "properties": {
        "dependent_metric": {
          "type": "string",
          "enum": ["success_ratio", "failure_ratio"]
        }
      }
    },
    "catalyst_enforcer": {
      "$ref": "#/definition/catalyst_constraints"
    }
  },
  "required": [
    "mandate_id",
    "custodian",
    "target_summary",
    "transitive_success_criteria",
    "catalyst_constraints"
  ],
  "dependencies": {
    "catalyst_enforcer": {
      "$ref": "#/properties/catalyst_enforcer"
    }
  },
  "definition": {
    "catalyst_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scope",
          "artifact_key",
          "operator",
          "dynamic_limit_value",
          "adjustment_interval"
        ],
        "properties": {
          "operator": {
            "type": "string",
            "enum": [
              "LT",
              "LTE",
              "EQ",
              "GT",
              "GTE",
              "PROHIBIT",
              "PROHIBIT_DELTA",
              "ADJUST"
            ]
          },
          "dynamic_limit_value": {
            "type": [
              "number",
              "string",
              "object",
              "array"
            ]
          },
          "adjustment_interval": {
            "type": "number"
          }
        }
      }
    }
  }
}