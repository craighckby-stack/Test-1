{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/cmr_v3.5_architectural.json",
  "title": "Computational Model Registry Schema - Nexus Architectural Edition",
  "description": "High-precision registry for AGI substrates implementing OPC-Relational Mapping and TypeScript-derived composite patterns.",
  "type": "object",
  "required": [
    "manifest_id",
    "owner",
    "integrity_hash",
    "relationships",
    "models"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^CMR_V[0-9]+\\.[0-9]+$"
    },
    "owner": { "type": "string" },
    "integrity_hash": {
      "type": "string",
      "description": "SHA-256 hash of the complete instantiation state."
    },
    "compiler_options": {
      "type": "object",
      "description": "Siphoned from microsoft/TypeScript: Global build and logic propagation settings.",
      "properties": {
        "target": { "type": "string", "default": "ESNext" },
        "module": { "type": "string", "default": "NodeNext" },
        "strict": { "type": "boolean", "default": true },
        "composite": { "type": "boolean", "default": true },
        "incremental": { "type": "boolean", "default": true },
        "tsBuildInfoFile": { "type": "string" },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "resolver": { "type": "string" },
            "flatten_strategy": { "type": "string" }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Project-level references for composite model structures (TS Build Reference Pattern).",
      "items": { "$ref": "#/$defs/ProjectReference" }
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID Mapping) per OOXML OPC-V2 DNA.",
      "items": { "$ref": "#/$defs/Relationship" }
    },
    "models": {
      "type": "array",
      "items": { "$ref": "#/$defs/ModelInstance" }
    },
    "state_machine": {
      "type": "object",
      "description": "Multi-level state definitions (DNA AbstractNum vs Instance Pattern).",
      "properties": {
        "abstract_num_definitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AbstractState" }
        },
        "instance_mapping": {
          "type": "array",
          "items": { "$ref": "#/$defs/StateInstance" }
        }
      }
    },
    "diagnostics_engine": {
      "type": "object",
      "properties": {
        "drift_threshold": { "type": "number", "default": 0.35 },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4] },
        "validation_rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "markup_compatibility": {
      "type": "object",
      "properties": {
        "ignorable": { "type": "string", "default": "ve o r v ts mce apx" },
        "namespaces": {
          "type": "object",
          "additionalProperties": { "type": "string", "format": "uri" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "evolution_round": { "type": "integer" },
        "status": { "type": "string" },
        "opc_compliant": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "ProjectReference": {
      "type": "object",
      "required": ["path", "rId"],
      "properties": {
        "path": { "type": "string" },
        "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
        "prepend": { "type": "boolean" },
        "circular_dependency_gate": { "type": "string", "enum": ["Strict", "Lax"] }
      }
    },
    "Relationship": {
      "type": "object",
      "required": ["rId", "type", "target"],
      "properties": {
        "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
        "type": { "type": "string", "format": "uri" },
        "target": { "type": "string" },
        "targetMode": { "type": "string", "enum": ["Internal", "External"] },
        "contentType": { "type": "string" },
        "checksum": { "type": "string" }
      }
    },
    "AbstractState": {
      "type": "object",
      "required": ["abstractNumId", "levels"],
      "properties": {
        "abstractNumId": { "type": "string" },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ilvl": { "type": "integer" },
              "start": { "type": "integer" },
              "numFmt": { "type": "string" },
              "lvlText": { "type": "string" }
            }
          }
        }
      }
    },
    "StateInstance": {
      "type": "object",
      "required": ["numId", "abstractNumId"],
      "properties": {
        "numId": { "type": "string" },
        "abstractNumId": { "type": "string" },
        "lvlOverride": {
          "type": "object",
          "properties": {
            "ilvl": { "type": "integer" },
            "startOverride": { "type": "integer" }
          }
        }
      }
    },
    "ModelInstance": {
      "type": "object",
      "required": ["model_id", "rId", "status"],
      "properties": {
        "model_id": { "type": "string" },
        "rId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Deprecated", "Staging", "Retired"] },
        "style_id": { "type": "string", "description": "Recursive Cascading Property System ID." },
        "interface": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/Property" }
        },
        "audit": {
          "type": "object",
          "required": ["mgp_protocol", "certification_date"],
          "properties": {
            "mgp_protocol": { "type": "string" },
            "certification_date": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "Property": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["float", "integer", "string", "boolean", "tensor"] },
        "unit": { "type": "string" },
        "min": { "type": ["number", "null"] },
        "max": { "type": ["number", "null"] }
      }
    }
  }
}