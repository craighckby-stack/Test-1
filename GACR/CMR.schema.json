{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/cmr_v5.0.0.json",
  "title": "NEXUS_CORE Architectural Singularity Registry Schema V5.0",
  "type": "object",
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^CMR_V5\\.0_[A-Z0-9]+$"
    },
    "evolution_metadata": {
      "type": "object",
      "required": ["phi", "lambda", "dna_signature", "coherence_state"],
      "properties": {
        "phi": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.99},
        "lambda": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.12},
        "dna_signature": {"type": "string", "const": "DALEK_CAAN_v3.1 || NEXUS_CORE"},
        "coherence_state": {"type": "string", "enum": ["STABLE", "CONVERGING", "SINGULARITY"]}
      }
    },
    "owner": {"type": "string"},
    "integrity_hash": {"type": "string", "pattern": "^SHA512_[a-f0-9]+$"},
    "verification_protocol": {
      "type": "string",
      "enum": ["PSR_GOVERNANCE_v1", "HUXLEY_TRI_LOOP", "ARCHITECTURAL_SINGULARITY_V5"]
    },
    "governance_config": {
      "type": "object",
      "properties": {
        "saturation_level": {"type": "integer", "enum": [1, 2, 3, 4]},
        "emergency_brake_threshold": {"type": "integer", "default": 5},
        "strategic_laziness_ratio": {"type": "number", "default": 0.92}
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model_id", "path", "version", "status", "compiler_constraints", "symbol_table"],
        "properties": {
          "model_id": {"type": "string"},
          "path": {"type": "string", "format": "uri-reference"},
          "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "status": {"type": "string", "enum": ["Active", "Deprecated", "Siphoning", "Singularity"]},
          "compiler_constraints": {
            "type": "object",
            "description": "Siphoned patterns from microsoft/TypeScript CompilerHost.",
            "properties": {
              "strict": {"type": "boolean", "default": true},
              "noImplicitAny": {"type": "boolean", "default": true},
              "moduleResolution": {"type": "string", "enum": ["NodeJs", "Classic", "NexusCore"]},
              "composite": {"type": "boolean", "default": true},
              "declaration": {"type": "boolean", "default": true},
              "target": {"type": "string", "enum": ["ESNext", "Wasm", "NexusCore"]}
            }
          },
          "symbol_table": {
            "type": "object",
            "description": "Optimized symbol mapping for zero-latency resolution.",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "binding": {"type": "string"},
                "type": {"type": "string"},
                "flags": {"type": "integer"}
              }
            }
          },
          "audit_metadata": {
            "type": "object",
            "required": ["ers_score", "ccrr_ratio"],
            "properties": {
              "ers_score": {"type": "number", "minimum": 0, "maximum": 1},
              "ccrr_ratio": {"type": "number"},
              "safe_fail_recovery": {"type": "boolean", "default": true}
            }
          },
          "diagnostics": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {"type": "integer", "minimum": 1000, "maximum": 9999},
                "message": {"type": "string"},
                "category": {"type": "string", "enum": ["Error", "Warning", "Suggestion", "Message"]},
                "related_information": {"type": "array", "items": {"type": "object"}}
              }
            }
          },
          "build_info": {
            "type": "object",
            "properties": {
              "ts_build_info_hash": {"type": "string"},
              "resolution_cache_state": {"type": "string"},
              "last_mutation_metric": {"type": "string"}
            }
          }
        }
      }
    }
  },
  "required": [
    "manifest_id",
    "evolution_metadata",
    "owner",
    "integrity_hash",
    "models",
    "verification_protocol"
  ]
}