{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "GACR/ModelTierMapping.schema.json",
  "title": "Model Tier Mapping Configuration Schema [NEXUS_CORE v3.1 Round 4]",
  "description": "Architectural substrate siphoning AlphaCode competitive-logic clustering and OOXML-DocX Relational Dependency logic. Implements Hierarchical Semantic Serialization for sub-50ms model tiering reconciliation.",
  "type": "object",
  "properties": {
    "mc:Ignorable": {
      "type": "string",
      "default": "nx mce ac react fiber lanes scheduler w r ts_ref"
    },
    "namespaces": {
      "type": "object",
      "additionalProperties": { "type": "string", "format": "uri" },
      "default": {
        "nx": "https://nexus-core.agi/governance",
        "mce": "http://schemas.openxmlformats.org/markup-compatibility/2006",
        "ac": "https://alphacode.deepmind/logic/v2",
        "react": "https://react.dev/core/reconciliation",
        "fiber": "https://react.dev/core/fiber-tree",
        "w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
        "r": "http://schemas.openxmlformats.org/officeDocument/2006/relationships"
      }
    },
    "mapping_version": {
      "type": "string",
      "enum": ["2.7.0-ALPHA_CORE"],
      "description": "AlphaCode-optimized precision mapping version with siphoned clustering heuristics."
    },
    "settings": {
      "type": "object",
      "properties": {
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "resolver": { "type": "string", "enum": ["RecursiveFlatten", "ShallowMerge", "AtomizedSiphon"] },
            "docDefaults": { "$ref": "#/$defs/tierProperties" }
          }
        },
        "ac:selection_policy": {
          "type": "object",
          "properties": {
            "sampling_mode": { "type": "string", "enum": ["Greedy", "BeamSearch", "NucleusSampling", "ClusteredVerification"] },
            "candidate_limit": { "type": "integer", "default": 1000000 },
            "clustering_threshold": { "type": "number", "default": 0.92 },
            "ac:filtering_heuristic": { "type": "string", "enum": ["UnitTesting", "ComplexityAnalysis", "SemanticEquivalence"] },
            "ac:solution_filtering": { "type": "boolean", "default": true }
          }
        },
        "w:settings": {
          "type": "object",
          "properties": {
            "proofState": { "type": "string", "enum": ["clean", "dirty"] },
            "nx:mirror_governance": { "type": "boolean", "default": true },
            "w:compat": {
              "type": "object",
              "properties": {
                "w:useNormalStyleForList": { "type": "boolean", "default": false },
                "w:doNotTrackMoves": { "type": "boolean", "default": true }
              }
            }
          }
        }
      }
    },
    "abstract_tier_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "abstractNumId": { "type": "string" },
          "name": { "type": "string" },
          "multiLevelType": { "type": "string", "enum": ["single", "hybridFiber", "multiLevel", "competitive", "clustered"] },
          "ac:problem_type": { "type": "string", "enum": ["Optimization", "Search", "Inference", "Deterministic", "CompetitiveReasoning", "HeuristicSynthesis"] },
          "levels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ilvl": { "type": "integer" },
                "tierPr": { "$ref": "#/$defs/tierProperties" },
                "fiber:workTag": { "type": "string" },
                "w:pPr": {
                  "type": "object",
                  "properties": {
                    "w:jc": { "type": "string" },
                    "w:spacing": { "type": "object" },
                    "w:ind": { "type": "object" }
                  }
                }
              },
              "required": ["ilvl", "tierPr"]
            }
          }
        },
        "required": ["abstractNumId", "name", "levels"]
      }
    },
    "tier_instance_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "numId": { "type": "string" },
          "abstractNumId": { "type": "string" },
          "rId": { "type": "string", "pattern": "^rId_[A-Z0-9]+$" },
          "status": { "type": "string", "enum": ["CONVERGED", "DEGRADED", "STABLE", "EVOLVING", "CLUSTERED", "SIPHONED"] },
          "fiber:key": { "type": "string" },
          "fiber:lanes": { "type": "string", "enum": ["Sync", "Default", "Input", "Idle", "Offscreen", "Deferred"] },
          "ac:pass_at_k": { "type": "number", "default": 1 },
          "ac:cluster_id": { "type": "string" },
          "ac:verification_state": { "type": "string", "enum": ["PENDING", "VERIFIED", "REJECTED"] }
        },
        "required": ["numId", "abstractNumId", "rId"]
      }
    },
    "relational_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rId": { "type": "string" },
          "type": { "type": "string", "format": "uri" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"] },
          "rule": {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "criteria": {
                "type": "object",
                "properties": {
                  "match_type": { "type": "string", "enum": ["exact_id", "tag_match", "regex_id", "ac_heuristic", "semantic_atom", "rel_indirection"] },
                  "values": { "type": "array", "items": { "type": "string" } },
                  "ac:competitive_score_min": { "type": "number" },
                  "ac:complexity_threshold": { "type": "string" },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "key": { "type": "string" },
                        "operator": { "type": "string", "enum": ["equals", "not_equals", "less_than", "greater_than", "ac_match", "regex"] },
                        "value": { "type": "string" }
                      }
                    }
                  }
                },
                "required": ["match_type"]
              }
            }
          }
        },
        "required": ["rId", "type", "target"]
      }
    }
  },
  "required": ["mapping_version", "abstract_tier_definitions", "tier_instance_mapping", "relational_dependencies"],
  "$defs": {
    "tierProperties": {
      "type": "object",
      "properties": {
        "priority_level": { "type": "integer" },
        "sla_target_ms": { "type": "integer" },
        "redundancy_level": { "type": "string" },
        "availability": { "type": "number", "minimum": 0, "maximum": 1 },
        "nx:governance_mode": { "type": "string", "enum": ["Strict", "Adaptive", "Passive", "Nuclear"] },
        "lanes:mask": { "type": "string", "pattern": "^0b[01]+$" },
        "scheduler:priority": { "type": "string", "enum": ["ImmediatePriority", "UserBlockingPriority", "NormalPriority", "LowPriority", "IdlePriority"] },
        "react:memoize": { "type": "boolean" },
        "ac:complexity_constraint": { "type": "string", "enum": ["O(1)", "O(logN)", "O(N)", "O(NlogN)", "O(N^2)", "O(2^N)", "Unbounded"] },
        "ac:memory_limit_mb": { "type": "integer", "default": 1024 },
        "ac:sampling_temperature": { "type": "number", "default": 0.7 },
        "w:rPr": {
          "type": "object",
          "properties": {
            "w:sz": { "type": "integer" },
            "w:b": { "type": "boolean" },
            "w:noProof": { "type": "boolean" },
            "w:vanish": { "type": "boolean" }
          }
        }
      },
      "required": ["priority_level", "sla_target_ms"]
    }
  }
}