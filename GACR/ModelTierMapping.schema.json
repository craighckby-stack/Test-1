{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "GACR/ModelTierMapping.schema.json",
  "title": "Model Tier Mapping Configuration Schema [NEXUS_CORE v3.1]",
  "description": "Architectural substrate for self-optimising model tiering using OOXML-DocX Relational Dependency and React-Fiber Concurrency patterns, siphoned with AlphaCode competitive-logic heuristics.",
  "type": "object",
  "properties": {
    "mc:Ignorable": {
      "type": "string",
      "default": "nx mce ac react fiber lanes scheduler"
    },
    "namespaces": {
      "type": "object",
      "additionalProperties": { "type": "string", "format": "uri" },
      "default": {
        "nx": "https://nexus-core.agi/governance",
        "mce": "http://schemas.openxmlformats.org/markup-compatibility/2006",
        "ac": "https://alphacode.deepmind/logic/v2",
        "react": "https://react.dev/core/reconciliation",
        "fiber": "https://react.dev/core/fiber-tree"
      }
    },
    "mapping_version": {
      "type": "string",
      "enum": ["2.5.0-CONVERGED"],
      "description": "NEXUS-grade version control with AlphaCode pattern optimization."
    },
    "settings": {
      "type": "object",
      "properties": {
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "resolver": { "type": "string", "enum": ["RecursiveFlatten", "ShallowMerge"] },
            "docDefaults": { "$ref": "#/$defs/tierProperties" }
          }
        },
        "ac:selection_policy": {
          "type": "object",
          "properties": {
            "sampling_mode": { "type": "string", "enum": ["Greedy", "BeamSearch", "NucleusSampling"] },
            "candidate_limit": { "type": "integer", "default": 1000 },
            "clustering_threshold": { "type": "number", "default": 0.85 }
          }
        }
      }
    },
    "abstract_tier_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "abstractNumId": { "type": "string" },
          "name": { "type": "string" },
          "multiLevelType": { "type": "string", "enum": ["single", "hybridFiber", "multiLevel"] },
          "ac:problem_type": { "type": "string", "enum": ["Optimization", "Search", "Inference", "Deterministic"] },
          "levels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ilvl": { "type": "integer" },
                "tierPr": { "$ref": "#/$defs/tierProperties" },
                "fiber:workTag": { "type": "string" }
              },
              "required": ["ilvl", "tierPr"]
            }
          }
        },
        "required": ["abstractNumId", "name", "levels"]
      }
    },
    "tier_instance_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "numId": { "type": "string" },
          "abstractNumId": { "type": "string" },
          "rId": { "type": "string", "pattern": "^rId_[A-Z0-9]+$" },
          "status": { "type": "string", "enum": ["CONVERGED", "DEGRADED", "STABLE", "EVOLVING"] },
          "fiber:key": { "type": "string" },
          "fiber:lanes": { "type": "string", "enum": ["Sync", "Default", "Input", "Idle"] },
          "ac:pass_at_k": { "type": "number", "description": "Probability of successful execution in k samples." }
        },
        "required": ["numId", "abstractNumId", "rId"]
      }
    },
    "relational_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rId": { "type": "string" },
          "type": { "type": "string", "format": "uri" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"] },
          "rule": {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "criteria": {
                "type": "object",
                "properties": {
                  "match_type": { "type": "string", "enum": ["exact_id", "tag_match", "regex_id", "ac_heuristic"] },
                  "values": { "type": "array", "items": { "type": "string" } },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "key": { "type": "string" },
                        "operator": { "type": "string", "enum": ["equals", "not_equals", "less_than", "greater_than"] },
                        "value": { "type": "string" }
                      }
                    }
                  }
                },
                "required": ["match_type"]
              }
            }
          }
        },
        "required": ["rId", "type", "target"]
      }
    }
  },
  "required": ["mapping_version", "abstract_tier_definitions", "tier_instance_mapping", "relational_dependencies"],
  "$defs": {
    "tierProperties": {
      "type": "object",
      "properties": {
        "priority_level": { "type": "integer" },
        "sla_target_ms": { "type": "integer" },
        "redundancy_level": { "type": "string" },
        "availability": { "type": "number", "minimum": 0, "maximum": 1 },
        "nx:governance_mode": { "type": "string", "enum": ["Strict", "Adaptive", "Passive"] },
        "lanes:mask": { "type": "string", "pattern": "^0b[01]+$" },
        "scheduler:priority": { "type": "string", "enum": ["ImmediatePriority", "UserBlockingPriority", "NormalPriority", "LowPriority", "IdlePriority"] },
        "react:memoize": { "type": "boolean" },
        "ac:complexity_constraint": { "type": "string", "enum": ["O(1)", "O(logN)", "O(N)", "O(NlogN)", "Unbounded"] }
      },
      "required": ["priority_level", "sla_target_ms"]
    }
  }
}