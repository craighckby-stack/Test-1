{
  "$id": "GACR/TelemetrySourceSchema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NEXUS_CORE Telemetry Aggregator (Architect-Precise v3.1.6)",
  "description": "High-order telemetry schema siphoned from Meta/React-Core Fiber and ISO/IEC 29500 (OOXML). Implements Triple-Buffering Reconciliation, Relational Dependency Indirection (rId), and Abstract State Machine inheritance for sequential telemetry streams.",
  "type": "array",
  "mc:Ignorable": "nx mce react fiber lanes scheduler w r ac hook docx",
  "items": {
    "type": "object",
    "properties": {
      "pStyle": {
        "type": "string",
        "description": "Cascading Style ID. Resolves property inheritance via recursive flat-map (Default -> Abstract -> Specific -> Local)."
      },
      "rId": {
        "type": "string",
        "pattern": "^rId[0-9]+$",
        "description": "Indirection Dependency Layer pointer. Maps to URI targets in the Relationship Manifest to decouple pathing from logic."
      },
      "reconciliation_node": {
        "type": "object",
        "properties": {
          "fiber_tag": { "type": "integer", "description": "Component type (0:Function, 1:Class, 3:HostRoot, 5:HostComponent)." },
          "lane_mask": { "type": "string", "pattern": "^0b[01]{5}$", "description": "Priority bitmask for concurrent scheduling (Sync, Input, Default, Transition, Idle)." },
          "scheduler_priority": { "type": "string", "enum": ["Immediate", "UserBlocking", "Normal", "Low", "Idle"] },
          "expiration_ms": { "type": "integer", "description": "Deadline for work completion." },
          "effect_tag": { "type": "string", "enum": ["Placement", "Update", "Deletion", "Hydrating"] },
          "react:transition": { "type": "string", "enum": ["deferred", "urgent", "background"] },
          "hook:useBatching": { "type": "string", "enum": ["Immediate", "Debounced", "Throttled"] },
          "alternate": {
            "type": "object",
            "description": "Work-In-Progress (WIP) Fiber node for triple-buffering reconciliation.",
            "properties": {
              "lanes:pending_mask": { "type": "string" },
              "fiber:pending_props": { "type": "object" },
              "react:effect_tag": { "type": "string" }
            }
          }
        },
        "required": ["lane_mask", "fiber_tag", "scheduler_priority"]
      },
      "sequential_state": {
        "type": "object",
        "properties": {
          "abstractNumId": { "type": "string", "description": "Blueprint logic for sequence counters." },
          "w:tmpl": { "type": "string", "description": "Template hex identifier for sequence formatting." },
          "numId": { "type": "string", "description": "Specific instance counter ID." },
          "ilvl": { "type": "integer", "minimum": 0, "maximum": 9 }
        }
      },
      "suspense_config": {
        "type": "object",
        "properties": {
          "fallback_rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "suspense_threshold_ms": { "type": "integer", "default": 250 },
          "hydration_strategy": { "type": "string", "enum": ["selective", "synchronous", "deferred"] },
          "react:useDeferredValue": { "type": "boolean", "default": true }
        }
      },
      "payload": {
        "type": "object",
        "properties": {
          "metric_value": { "type": ["number", "string", "boolean"] },
          "data_type": { "type": "string", "enum": ["GAUGE", "COUNTER", "BOOLEAN", "HISTOGRAM"] },
          "timestamp_ms": { "type": "integer", "format": "int64" },
          "ac:complexity_limit": { "type": "integer", "default": 1500 },
          "ac:cooldown_period": { "type": "integer", "default": 30 }
        },
        "required": ["metric_value", "timestamp_ms"]
      },
      "core_properties": {
        "type": "object",
        "properties": {
          "dc:title": { "type": "string" },
          "docx:version": { "type": "string" },
          "docx:revision": { "type": "integer" },
          "docx:lastModifiedBy": { "type": "string" },
          "docx:contentStatus": { "type": "string", "default": "Architecturally_Precise" },
          "react:flags": { 
            "type": "object", 
            "properties": {
              "enableSchedulingProfiler": { "type": "boolean" },
              "enableSuspenseCallback": { "type": "boolean" },
              "enableSelectiveHydration": { "type": "boolean" },
              "useAlternativeFiberRoot": { "type": "boolean" }
            }
          }
        }
      }
    },
    "required": ["pStyle", "rId", "reconciliation_node", "payload"]
  },
  "definitions": {
    "RelationshipManifest": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Id": { "type": "string" },
          "Type": { "type": "string", "format": "uri" },
          "Target": { "type": "string" },
          "TargetMode": { "type": "string", "enum": ["Internal", "External"] },
          "ac:verification_logic": { "type": "string", "default": "HMAC-SHA512" }
        },
        "required": ["Id", "Type", "Target"]
      }
    },
    "StyleChain": {
      "type": "object",
      "properties": {
        "styleId": { "type": "string" },
        "basedOn": { "type": "string" },
        "next": { "type": "string" },
        "rPrDefault": { 
          "type": "object",
          "properties": {
            "react:memoize": { "type": "boolean" },
            "fiber:expiration_ms": { "type": "integer" }
          }
        },
        "pPrDefault": { 
          "type": "object",
          "properties": {
            "scheduler:priority": { "type": "string" },
            "nx:governance_mode": { "type": "string" }
          }
        }
      }
    }
  }
}