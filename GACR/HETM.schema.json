{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://nexus.core/schemas/v97.1/HETM.json",
  "title": "NEXUS_CORE Host Environment Trust Manifest (HETM)",
  "description": "Final-tier specification for verified computational substrates under GRTS protocol, integrating Huxley Tri-Loop telemetry and N=3 coherence metrics.",
  "type": "object",
  "required": [
    "manifest_id",
    "version",
    "required_platform_measurement",
    "cognitive_telemetry",
    "n3_state_vector",
    "transport_constraints",
    "attestation_signature"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "const": "GTEM_V97.1",
      "description": "Immutable manifest identifier bound to the siphoning cycle."
    },
    "version": {
      "type": "string",
      "const": "3.1.0",
      "description": "DALEK CAAN Evolution Version."
    },
    "required_platform_measurement": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{96}$",
      "description": "SHA384 cryptographic attestation of the host boot state."
    },
    "cognitive_telemetry": {
      "type": "object",
      "required": [
        "S01_efficacy_metric",
        "S02_risk_metric",
        "S03_veto_signal",
        "ers_score"
      ],
      "properties": {
        "S01_efficacy_metric": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "S02_risk_metric": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "S03_veto_signal": {
          "type": "boolean"
        },
        "ers_score": {
          "type": "number",
          "description": "Ethical Risk Score (Huxley L1)."
        },
        "cgs_ratio": {
          "type": "number",
          "description": "Certainty Gain vs Time Penalty (Huxley L2)."
        }
      }
    },
    "n3_state_vector": {
      "type": "object",
      "required": [
        "phi_integrated_info",
        "lambda_chaos_proximity"
      ],
      "properties": {
        "phi_integrated_info": {
          "type": "number",
          "description": "Total system unity (Metric Φ)."
        },
        "lambda_chaos_proximity": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 0.8,
          "description": "Operational temperature equivalent (Metric λ)."
        },
        "coherence_status": {
          "type": "string",
          "enum": [
            "STABLE",
            "EVOLVING",
            "SATURATED",
            "DEGRADED"
          ]
        }
      }
    },
    "triumvirate_segmentation": {
      "type": "object",
      "properties": {
        "memory_isolation": {
          "type": "string",
          "enum": [
            "Strict",
            "Hardened",
            "Isolated"
          ]
        },
        "enclave_type": {
          "type": "string",
          "enum": [
            "SGX",
            "TDX",
            "AMD-SEV"
          ]
        }
      }
    },
    "transport_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "endpoint_id": {
            "type": "string"
          },
          "protocol": {
            "type": "string",
            "const": "HTTPS/TLS_1_3"
          },
          "max_latency_ms": {
            "type": "integer",
            "const": 500
          }
        }
      }
    },
    "attestation_signature": {
      "type": "object",
      "required": [
        "algorithm",
        "payload_hash",
        "crot_signature"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "SHA3-256"
        },
        "payload_hash": {
          "type": "string"
        },
        "crot_signature": {
          "type": "string",
          "description": "Base64 encoded CRoT signature via safeUtoa."
        }
      }
    }
  },
  "additionalProperties": false
}