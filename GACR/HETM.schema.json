{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/ecvm_tis_v10.5.0_round_2.json",
  "title": "NEXUS_CORE Host Environment Trust Manifest (HETM) - Evolutionary Round 2",
  "description": "Siphoned Architectural Trust Manifest. Integrates OOXML RID-indirection and TypeScript project-reference hierarchies for metabolic state governance.",
  "type": "object",
  "required": [
    "manifest_id",
    "version",
    "relationships",
    "parts",
    "state_machine",
    "attestation_signature"
  ],
  "markup_compatibility": {
    "ignorable": "dalek v3 nx_ext mce",
    "namespaces": {
      "w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
      "r": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
      "nx": "https://nexus-core.agi/governance",
      "mc": "http://schemas.openxmlformats.org/markup-compatibility/2006",
      "nx_ext": "https://nexus-core.agi/extensions/v5"
    }
  },
  "properties": {
    "manifest_id": {
      "type": "string",
      "const": "GTEM_V10.5.0"
    },
    "version": {
      "type": "string",
      "const": "10.5.0-FINAL"
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID). Traceable to .rels manifest logic.",
      "items": {
        "type": "object",
        "properties": {
          "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "type": { "type": "string" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"] }
        },
        "required": ["rId", "type", "target"]
      }
    },
    "compiler_options": {
      "type": "object",
      "description": "TS-grade orchestration for composite substrate compilation.",
      "properties": {
        "composite": { "type": "boolean", "default": true },
        "incremental": { "type": "boolean", "default": true },
        "noUncheckedIndexedAccess": { "type": "boolean", "default": true },
        "verbatimModuleSyntax": { "type": "boolean", "default": true },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "depth_limit": { "type": "integer", "maximum": 50 },
            "resolver": { "type": "string", "const": "RecursiveFlatten" }
          }
        }
      }
    },
    "parts": {
      "type": "array",
      "description": "Atomized Semantic Tree: Blocks, Inlines, and Terminals.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "rId": { "type": "string" },
          "status": { "type": "string", "enum": ["STABLE", "EVOLVING", "SATURATED", "DEGRADED", "CONVERGED"] },
          "atomized_layers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "layer_type": { "type": "string", "enum": ["Block", "Inline", "Terminal"] },
                "inheritance": { "type": "string", "enum": ["Inherit", "Override", "Final"] },
                "pPr": { "$ref": "#/definitions/StyleProperties" },
                "rPr": { "$ref": "#/definitions/StyleProperties" },
                "content_ref": { "type": "string" }
              }
            }
          }
        },
        "required": ["id", "rId", "status"]
      }
    },
    "state_machine": {
      "type": "object",
      "description": "Multi-Level Sequential State (OOXML Numbering Logic).",
      "properties": {
        "abstract_num_definitions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "abstractNumId": { "type": "string" },
              "levels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "ilvl": { "type": "integer" },
                    "start": { "type": "integer" },
                    "numFmt": { "type": "string" },
                    "lvlText": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "instance_mapping": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "numId": { "type": "string" },
              "abstractNumId": { "type": "string" }
            }
          }
        }
      }
    },
    "diagnostics_engine": {
      "type": "object",
      "properties": {
        "drift_threshold": { "type": "number", "const": 0.35 },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4] },
        "validation_rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "emergency_brake": {
          "type": "object",
          "properties": {
            "corruption_threshold": { "type": "integer", "const": 5 },
            "auto_halt": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "attestation_signature": {
      "type": "object",
      "required": ["algorithm", "payload_hash", "crot_signature"],
      "properties": {
        "algorithm": { "type": "string", "const": "SHA3-256" },
        "payload_hash": { "type": "string" },
        "crot_signature": { "type": "string" }
      }
    }
  },
  "definitions": {
    "StyleProperties": {
      "type": "object",
      "properties": {
        "val": { "type": ["string", "integer", "boolean"] },
        "inheritance": { "type": "string", "enum": ["Inherit", "Override", "Final"], "default": "Inherit" },
        "sz": { "type": "integer" },
        "color": { "type": "string", "pattern": "^[0-9A-F]{6}$" },
        "bold": { "type": "boolean" },
        "spacing": { 
          "type": "object", 
          "properties": { "val": { "type": "integer" }, "unit": { "type": "string", "enum": ["twips", "pts", "px"] } }
        },
        "ind": { 
          "type": "object", 
          "properties": { "val": { "type": "integer" }, "unit": { "type": "string", "enum": ["twips", "pts", "px"] } }
        },
        "jc": { "type": "object", "properties": { "val": { "type": "string", "enum": ["left", "center", "right", "both"] } } }
      }
    }
  },
  "metadata": {
    "dna_anchor": "ARCH-OOXML-V2-DOCX-DNA",
    "evolution_round": 2,
    "saturation_level": 2,
    "author": "DALEK_CAAN_V3.1_SIPHON_ENGINE",
    "identity_anchors_enforced": true,
    "last_mutation": "2026-03-02T18:15:00Z"
  }
}