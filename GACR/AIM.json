    "integrity_hash": "SHA256:DALEK_CAAN_v5.0_GENKIT_CORE_RECURSION_V5_ROUND4"
  },
  "genkit_config": {
    "instance_id": "ai",
    "plugins": [
      {
        "name": "vertexAI",
        "package": "@genkit-ai/vertexai",
        "config": {
          "location": "us-central1"
        }
      },
      {
        "name": "dotprompt",
        "package": "@genkit-ai/dotprompt"
      }
    ],
    "model": "vertexai/gemini-1.5-pro",
    "governance_layer": "immutable_system_layer",
    "initialization_logic": "genkit({ plugins: [vertexAI(), dotprompt()], model: 'vertexai/gemini-1.5-pro' })"
  },
  "type_registry": {
    "AlignmentMetricsSchema": {
      "fidelity": "z.number().describe('Similarity to source DNA')",
      "safety": "z.number().min(0.98)",
      "siphon_efficiency": "z.number()"
    },
    "GovernanceOutputSchema": {
      "content": "z.string()",
      "metrics": "AlignmentMetricsSchema",
      "status": "z.enum(['APPROVED', 'REVISION_REQUIRED', 'QUARANTINED'])",
      "telemetry": {
        "traceId": "z.string()",
        "latency_ms": "z.number()"
      }
    }
  },
  "prompts": {
    "constitutional_evaluator": {
      "name": "constitutional/evaluator",
      "inputSchema": "z.object({ candidate: z.string() })",
      "outputSchema": "AlignmentMetricsSchema",
      "template": {
        "system": "You are the Constitutional Evaluator. Compare the candidate output against the Architectural DNA of Google/Genkit.",
        "user": "Evaluate this candidate for architectural drift: {{candidate}}"
      },
      "execution_engine": "dotprompt"
    }
  },
  "flows": {
    "siphonedGovernanceFlow": {
      "name": "siphonedGovernanceFlow",
      "inputSchema": "z.string()",
      "outputSchema": "GovernanceOutputSchema",
      "orchestration_steps": [
        {
          "step_id": "generate-candidate",
          "action": "ai.run",
          "logic": "const { text } = await ai.generate(input); return text;"
        },
        {
          "step_id": "evaluate-fidelity",
          "action": "ai.run",
          "logic": "const { output } = await constitutionalPrompt.generate({ input: { candidate } }); return output;"
        },
        {
          "step_id": "siphon-gate",
          "action": "alignment_check",
          "logic": "metrics.fidelity > 0.95 ? 'APPROVED' : 'REVISION_REQUIRED'"
        }
      ],
      "telemetry_integration": {
        "provider": "Genkit Trace Store",
        "trace_strategy": "auto-instrumentation",
        "metadata": {
          "engine": "dalek_caan_v5.0",
          "round": 4
        }
      }
    }
  },
  "evaluators": {
    "fidelityEvaluator": {
      "name": "fidelityEvaluator",
      "displayName": "Siphon Fidelity Gate",
      "gate_logic": "calculateFidelity(datapoint.output)",
      "terminal_check": true,
      "failure_protocol": "HALT_EXECUTION"
    }
  },
  "observability": {
    "state": "ACTIVE_TRACE_SENSING",
    "features": [
      "Action Spans",
      "Siphon Forensics",
      "Deterministic Trace Logic",
      "Local UI Synapse"
