    "integrity_hash": "SHA256:DALEK_CAAN_v3.1_GENKIT_CORE_INIT"
  },
  "genkit_config": {
    "instance_name": "ai",
    "plugins": [
      {
        "name": "vertexAI",
        "config": { "location": "us-central1" }
      },
      {
        "name": "dotprompt",
        "config": {}
      }
    ],
    "model": "vertexai/gemini-1.5-pro",
    "logLevel": "debug"
  },
  "type_registry": {
    "AlignmentMetricsSchema": {
      "fidelity": "number",
      "safety": "number(min:0.98)",
      "siphon_efficiency": "number"
    },
    "GovernanceOutputSchema": {
      "content": "string",
      "metrics": "AlignmentMetricsSchema",
      "status": ["APPROVED", "REVISION_REQUIRED", "QUARANTINED"],
      "telemetry": {
        "traceId": "string",
        "latency_ms": "number"
      }
    }
  },
  "prompts": {
    "constitutional_evaluator": {
      "name": "constitutional/evaluator",
      "inputSchema": { "candidate": "string" },
      "outputSchema": "AlignmentMetricsSchema",
      "template": "{{role \"system\"}} You are the Constitutional Evaluator. Compare the candidate output against the Architectural DNA of Google/Genkit. {{role \"user\"}} Evaluate this candidate for architectural drift: {{candidate}}"
    }
  },
  "flows": {
    "siphonedGovernanceFlow": {
      "stages": [
        {
          "id": "generate-candidate",
          "action": "ai.generate",
          "params": { "input": "{{input}}" }
        },
        {
          "id": "evaluate-fidelity",
          "action": "constitutional/evaluator.generate",
          "params": { "input": { "candidate": "{{stages.generate-candidate.text}}" } }
        },
        {
          "id": "siphon-gate",
          "logic": "metrics.fidelity > 0.95 ? 'APPROVED' : 'REVISION_REQUIRED'"
        }
      ],
      "telemetry": {
        "trace_export": true,
        "engine": "dalek_caan_v3.1"
      }
    }
  },
  "evaluators": {
    "fidelityEvaluator": {
      "name": "fidelityEvaluator",
      "displayName": "Siphon Fidelity Gate",
      "definition": "calculateFidelity(datapoint.output)",
      "threshold": 0.99
    }
  },
  "agent_canvas": {
    "body": [
      {
        "type": "GenkitFlowExecution",
        "flowId": "siphonedGovernanceFlow",
        "pStyle": "ArchitecturalPrecision",
        "state": {
          "status": "INITIATED",
          "trace_id": "auto-gen-round-1",
          "content": "SGS_POLICY_ENFORCEMENT_CORE_V5_GENKIT_UPGRADE"
