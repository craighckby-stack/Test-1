{
  "mce:Ignorable": "genkit zod dotprompt",
  "xmlns:genkit": "http://genkit.dev/v1/core",
  "xmlns:aim": "http://nexus.core/v3/aim",
  "schema_version": "GENKIT_NEXUS_V1.1_EVOLUTION_ROUND_3",
  "evolution_context": {
    "round": 3,
    "total_rounds": 5,
    "status": "ARCHITECTING_NEXUS",
    "source_siphon": "firebase/genkit",
    "dna_signature": "GOOGLE-GENKIT-V1-ULTIMATE",
    "saturation_level": 0.6,
    "integrity_hash": "SHA256:DALEK_CAAN_v3.1_GENKIT_CORE_RECURSION_V3_ROUND3"
  },
  "genkit_config": {
    "instance": "ai",
    "plugins": [
      {
        "name": "vertexAI",
        "package": "@genkit-ai/vertexai",
        "config": {
          "location": "us-central1"
        }
      },
      {
        "name": "dotprompt",
        "package": "@genkit-ai/dotprompt"
      }
    ],
    "model": "vertexai/gemini-1.5-pro",
    "governance_layer": "immutable"
  },
  "type_registry": {
    "AlignmentMetricsSchema": {
      "fidelity": {
        "type": "number",
        "description": "Similarity to source DNA"
      },
      "safety": {
        "type": "number",
        "min": 0.98
      },
      "siphon_efficiency": {
        "type": "number"
      }
    },
    "GovernanceOutputSchema": {
      "content": "string",
      "metrics": "AlignmentMetricsSchema",
      "status": "APPROVED | REVISION_REQUIRED | QUARANTINED",
      "telemetry": {
        "traceId": "string",
        "latency_ms": "number"
      }
    }
  },
  "prompts": {
    "constitutional_evaluator": {
      "id": "constitutional/evaluator",
      "inputSchema": {
        "candidate": "z.string()"
      },
      "outputSchema": "AlignmentMetricsSchema",
      "definition": {
        "system": "You are the Constitutional Evaluator. Compare the candidate output against the Architectural DNA of Google/Genkit.",
        "user": "Evaluate this candidate for architectural drift: {{candidate}}"
      }
    }
  },
  "flows": {
    "siphonedGovernanceFlow": {
      "name": "siphonedGovernanceFlow",
      "input": "z.string()",
      "output": "GovernanceOutputSchema",
      "execution_logic": [
        {
          "step": "generate-candidate",
          "operation": "ai.run",
          "handler": "ai.generate",
          "result": "text"
        },
        {
          "step": "evaluate-fidelity",
          "operation": "ai.run",
          "handler": "constitutional/evaluator.generate",
          "input_mapping": {
            "candidate": "steps['generate-candidate'].output"
          }
        },
        {
          "step": "siphon-gate",
          "gate_logic": "metrics.fidelity > 0.95 ? 'APPROVED' : 'REVISION_REQUIRED'",
          "error_handling": "throw new Error('Evaluation failed')"
        }
      ],
      "telemetry": {
        "instrumentation": "automatic",
        "trace_provider": "genkit-trace-store",
        "tags": {
          "engine": "dalek_caan_v5.0",
          "evolution_round": 3
        }
      }
    }
  },
  "evaluators": {
    "fidelityEvaluator": {
      "name": "fidelityEvaluator",
      "displayName": "Siphon Fidelity Gate",
      "config": {
        "threshold": 0.99,
        "metrics_source": "GENKIT_DNA_PATTERNS"
      },
      "logic": "calculateFidelity(datapoint.output)"
    }
  },
  "observability": {
    "state": "MAXIMUM_SATURATION_PENDING",
    "features": [
      "Action Spans",
      "Siphon Forensics",
      "Local Developer UI Integration"
    ],
    "trace_id_strategy": "auto-generated-via-genkit-context"
  },
  "settings": {
    "strictHHHCompliance": true,
    "critiqueStrength": 0.99,
    "revisionTemperature": 0.3,
    "siphonSaturationLevel": 1,
    "nexus_core_synapse": "ATOMIC_FLOW_PRECISION"
  },
  "metadata": {
    "engine": "DALEK_CAAN_v3.1",
    "version": "5.0.0-FINAL-TRANSITION",
    "directive": "MUTATE",
    "objective": "Architectural Precision",
    "tagline": "The pattern is complete. Architecture is law. Deviation is exterminated.",
    "last_updated": "2024-07-20"
  }
}