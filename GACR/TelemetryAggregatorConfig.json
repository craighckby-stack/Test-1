{
  "mc:Ignorable": "nx mce react fiber lanes scheduler w r ac",
  "namespaces": {
    "nx": "https://nexus-core.agi/governance",
    "mce": "http://schemas.openxmlformats.org/markup-compatibility/2006",
    "react": "https://react.dev/core/reconciliation",
    "fiber": "https://react.dev/core/fiber-tree",
    "lanes": "https://react.dev/core/concurrent-lanes",
    "scheduler": "https://react.dev/core/scheduler",
    "w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    "r": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
    "ac": "https://alphacode.deepmind/logic/v2"
  },
  "Metadata": {
    "cp:coreProperties": {
      "dc:title": "GACR.TelemetryAggregator",
      "cp:version": "3.1.0-CONVERGED",
      "cp:lastModifiedBy": "DALEK_CAAN_v3.1",
      "cp:revision": "2"
    }
  },
  "Settings": {
    "w:docDefaults": {
      "pPrDefault": {
        "scheduler:priority": "Normal",
        "nx:governance_mode": "Adaptive",
        "lanes:mask": "0b00100"
      },
      "rPrDefault": {
        "react:memoize": true,
        "ac:complexity_limit": 1000
      }
    },
    "cascading_inheritance": {
      "resolver": "RecursiveFlatten",
      "depth_limit": 8
    }
  },
  "Styles": [
    {
      "styleId": "HighThroughput",
      "type": "paragraph",
      "scheduler:priority": "UserBlocking",
      "lanes:mask": "0b00001",
      "ac:threshold_logic": "Deterministic"
    },
    {
      "styleId": "BufferedStream",
      "type": "paragraph",
      "basedOn": "HighThroughput",
      "scheduler:priority": "Low",
      "lanes:mask": "0b10000"
    },
    {
      "styleId": "SchemaEnforcement",
      "type": "character",
      "react:memoize": true,
      "w:color": "FF0000"
    }
  ],
  "Parts": {
    "Sources": [
      {
        "rId": "rId1",
        "w:pStyle": "HighThroughput",
        "fiber:key": "ingress-http-primary"
      },
      {
        "rId": "rId2",
        "w:pStyle": "BufferedStream",
        "fiber:key": "ingress-kafka-trace"
      }
    ],
    "Destinations": [
      {
        "rId": "rId3",
        "mce:compatibility_mode": "v5.0",
        "scheduler:priority": "Normal"
      },
      {
        "rId": "rId4",
        "scheduler:priority": "Immediate",
        "lanes:mask": "0b00010"
      }
    ]
  },
  "Processing": {
    "fiber_tree_reconciliation": {
      "fiber:tag": 3,
      "type": "Block",
      "w:pStyle": "HighThroughput",
      "runs": [
        {
          "rStyle": "SchemaEnforcement",
          "react:effect_tag": "Update",
          "terminal": { "value": "ValidateJsonSchema" }
        },
        {
          "ac:complexity_limit": 500,
          "react:effect_tag": "Placement",
          "terminal": { "value": "DynamicFilter" }
        },
        {
          "nx:governance_mode": "Strict",
          "react:effect_tag": "Deletion",
          "terminal": { "value": "PiiAnonymization" }
        }
      ],
      "child": [
        {
          "type": "Inline",
          "w:pStyle": "BufferedStream",
          "runs": [
            {
              "lanes:active": "UserBlocking",
              "terminal": { "is_field": true, "field_type": "TIMER", "value": "AggregationLat" }
            }
          ]
        }
      ]
    },
    "SchedulerConfig": {
      "Enabled": true,
      "TargetCPUUtilization": 0.75,
      "Batching": {
        "MaxEvents": 5000,
        "MaxLatencyMS": 1000,
        "Compression": "Zstd"
      }
    }
  },
  "Relationships": [
    {
      "rId": "rId1",
      "type": "http://nexus-core.agi/rel/source/http",
      "target": "/api/v2/metrics",
      "targetMode": "Internal"
    },
    {
      "rId": "rId2",
      "type": "http://nexus-core.agi/rel/source/kafka",
      "target": "gacr.telemetry.traces",
      "targetMode": "Internal"
    },
    {
      "rId": "rId3",
      "type": "http://nexus-core.agi/rel/destination/s3",
      "target": "s3://gacr-telemetry-archive-v2",
      "targetMode": "External"
    },
    {
      "rId": "rId4",
      "type": "http://nexus-core.agi/rel/destination/monitor",
      "target": "http://monitor.gacr.internal:9091",
      "targetMode": "External"
    }
  ]
}