{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "GACR/Schemas/APITelemetry.json",
  "title": "API Performance Metrics Telemetry Schema [NEXUS_CORE v3.1 CONVERGED]",
  "description": "Final Evolution State: Siphoning OOXML-DocX Indirection Dependency Layers and React-Core Fiber Reconciliation. Implements Hierarchical Semantic Serialization, Recursive Cascading Property Inheritance, and Multi-Level State Machines for sub-50ms telemetry resolution across concurrent lanes.",
  "type": "object",
  "mc:Ignorable": "nx mce react fiber lanes scheduler w r ac",
  "namespaces": {
    "nx": "https://nexus-core.agi/governance",
    "mce": "http://schemas.openxmlformats.org/markup-compatibility/2006",
    "react": "https://react.dev/core/reconciliation",
    "fiber": "https://react.dev/core/fiber-tree",
    "lanes": "https://react.dev/core/concurrent-lanes",
    "scheduler": "https://react.dev/core/scheduler",
    "w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    "r": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
    "ac": "https://alphacode.deepmind/logic/v2"
  },
  "properties": {
    "telemetry_version": { "type": "string", "enum": ["3.1.0-CONVERGED"] },
    "timestamp_ms": { "type": "integer" },
    "settings": {
      "type": "object",
      "description": "Global Configuration Object (word/settings.xml). Defines document-wide behavior for the telemetry session.",
      "properties": {
        "nx:mirror_governance": { "type": "boolean", "default": true },
        "mce:compatibility_mode": { "type": "string", "default": "v5.0" },
        "w:docDefaults": {
          "type": "object",
          "description": "Base properties for the inheritance chain.",
          "properties": {
            "pPrDefault": { "$ref": "#/$defs/paragraphProperties" },
            "rPrDefault": { "$ref": "#/$defs/runProperties" }
          }
        },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "resolver": { "type": "string", "enum": ["RecursiveFlatten", "AtomizedSiphon"], "default": "RecursiveFlatten" },
            "depth_limit": { "type": "integer", "default": 8 }
          }
        }
      }
    },
    "styles": {
      "type": "array",
      "description": "State Inheritance Hierarchy (word/styles.xml). Supports Latent Styling and Local Overrides.",
      "items": {
        "type": "object",
        "properties": {
          "styleId": { "type": "string" },
          "type": { "type": "string", "enum": ["paragraph", "character"] },
          "basedOn": { "type": "string", "description": "Recursive parent style ID." },
          "pPr": { "$ref": "#/$defs/paragraphProperties" },
          "rPr": { "$ref": "#/$defs/runProperties" },
          "ac:threshold_logic": { "type": "string", "enum": ["Clustered", "Deterministic"] }
        },
        "required": ["styleId", "type"]
      }
    },
    "abstract_event_definitions": {
      "type": "array",
      "description": "Multi-Level State Definitions (word/numbering.xml). Abstract templates for telemetry sequencing logic.",
      "items": {
        "type": "object",
        "properties": {
          "abstractNumId": { "type": "string" },
          "multiLevelType": { "type": "string", "enum": ["hybridFiber", "competitive", "clustered"] },
          "levels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ilvl": { "type": "integer" },
                "scheduler:priority": { "type": "string", "enum": ["Immediate", "UserBlocking", "Normal", "Low", "Idle"] },
                "lanes:mask": { "type": "string" },
                "w:pPr": { "$ref": "#/$defs/paragraphProperties" }
              },
              "required": ["ilvl"]
            }
          }
        },
        "required": ["abstractNumId", "levels"]
      }
    },
    "event_instances": {
      "type": "array",
      "description": "Sequential State Sync (word/numbering.xml instances). Binds runtime events to templates via rId indirection.",
      "items": {
        "type": "object",
        "properties": {
          "numId": { "type": "string" },
          "abstractNumId": { "type": "string" },
          "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "fiber:key": { "type": "string" }
        },
        "required": ["numId", "abstractNumId", "rId"]
      }
    },
    "telemetry_fiber_tree": {
      "type": "array",
      "description": "Atomized Semantic Tree following the Paragraph (Block Context) & Run (Inline Metrics) pattern.",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["Block", "Inline"] },
          "fiber:tag": { "type": "integer" },
          "w:pStyle": { "type": "string", "description": "Refers to styles.styleId or event_instances.numId." },
          "pPr": { "$ref": "#/$defs/paragraphProperties" },
          "runs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rStyle": { "type": "string" },
                "rPr": { "$ref": "#/$defs/runProperties" },
                "lifecycle": {
                  "type": "object",
                  "properties": {
                    "render": {
                      "properties": {
                        "duration": { "type": "number" },
                        "lanes:active": { "type": "string" }
                      }
                    },
                    "commit": {
                      "properties": {
                        "mutation_count": { "type": "integer" },
                        "react:effect_tag": { "type": "string" }
                      }
                    }
                  }
                },
                "terminal": {
                  "type": "object",
                  "description": "The 'Text' level data or 'Field' logic.",
                  "properties": {
                    "is_field": { "type": "boolean" },
                    "field_type": { "type": "string", "enum": ["COUNTER", "TIMER", "REF", "FIBER_KEY"] },
                    "value": { "type": "string" }
                  }
                }
              }
            }
          },
          "child": { "type": "array", "items": { "$ref": "#/properties/telemetry_fiber_tree/items" } }
        },
        "required": ["type"]
      }
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (_rels/.rels). Decouples telemetry identifiers from logical/physical targets.",
      "items": {
        "type": "object",
        "properties": {
          "rId": { "type": "string" },
          "type": { "type": "string", "format": "uri" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"] },
          "ac:verification_logic": { "type": "string" }
        },
        "required": ["rId", "type", "target"]
      }
    }
  },
  "required": ["telemetry_version", "timestamp_ms", "settings", "telemetry_fiber_tree", "relationships"],
  "$defs": {
    "paragraphProperties": {
      "type": "object",
      "properties": {
        "w:jc": { "type": "string", "enum": ["start", "center", "end", "both"] },
        "scheduler:priority": { "type": "string" },
        "fiber:lanes": { "type": "string" },
        "nx:governance_mode": { "type": "string", "enum": ["Strict", "Adaptive"] }
      }
    },
    "runProperties": {
      "type": "object",
      "properties": {
        "w:color": { "type": "string" },
        "w:sz": { "type": "integer", "description": "Size metric (half-points equivalent)." },
        "w:b": { "type": "boolean" },
        "react:memoize": { "type": "boolean" },
        "ac:complexity_limit": { "type": "integer" }
      }
    }
  }
}