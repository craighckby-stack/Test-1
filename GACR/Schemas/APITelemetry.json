{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "GACR/Schemas/APITelemetry.json",
  "title": "API Performance Metrics Telemetry Schema [NEXUS_CORE v3.1 MUTATION_4]",
  "description": "Architectural Convergence: Siphoning OOXML-DocX Indirection Dependency Layers and React Fiber Concurrent Lanes. Implements a Recursive Cascading Property System and Multi-Level State Machines for atomized telemetry reconciliation.",
  "type": "object",
  "mc:Ignorable": "nx mce react fiber lanes scheduler w r ac",
  "namespaces": {
    "nx": "https://nexus-core.agi/governance",
    "mce": "http://schemas.openxmlformats.org/markup-compatibility/2006",
    "react": "https://react.dev/core/reconciliation",
    "fiber": "https://react.dev/core/fiber-tree",
    "lanes": "https://react.dev/core/concurrent-lanes",
    "scheduler": "https://react.dev/core/scheduler",
    "w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    "r": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
    "ac": "https://alphacode.deepmind/logic/v2"
  },
  "properties": {
    "timestamp_ms": { "type": "integer" },
    "settings": {
      "type": "object",
      "description": "Global Configuration Object (word/settings.xml) for session-wide telemetry flags.",
      "properties": {
        "nx:mirror_governance": { "type": "boolean", "default": true },
        "mce:compatibility_mode": { "type": "string", "default": "v5.0" },
        "w:docDefaults": {
          "type": "object",
          "properties": {
            "pPrDefault": { "$ref": "#/$defs/paragraphProperties" },
            "rPrDefault": { "$ref": "#/$defs/runProperties" }
          }
        },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "resolver": { "type": "string", "enum": ["RecursiveFlatten", "AtomizedSiphon"], "default": "RecursiveFlatten" },
            "depth_limit": { "type": "integer", "default": 4 }
          }
        }
      }
    },
    "styles": {
      "type": "array",
      "description": "State Inheritance Hierarchy (word/styles.xml). Maps Latent Styling to telemetry nodes.",
      "items": {
        "type": "object",
        "properties": {
          "styleId": { "type": "string" },
          "type": { "type": "string", "enum": ["paragraph", "character"] },
          "basedOn": { "type": "string", "description": "Recursive parent style reference." },
          "pPr": { "$ref": "#/$defs/paragraphProperties" },
          "rPr": { "$ref": "#/$defs/runProperties" },
          "ac:competitive_threshold": { "type": "number" }
        },
        "required": ["styleId", "type"]
      }
    },
    "abstract_event_definitions": {
      "type": "array",
      "description": "Multi-Level State Definitions (word/numbering.xml). Logic templates for event sequencing.",
      "items": {
        "type": "object",
        "properties": {
          "abstractNumId": { "type": "string" },
          "multiLevelType": { "type": "string", "enum": ["hybridFiber", "competitive", "clustered"] },
          "levels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ilvl": { "type": "integer" },
                "scheduler:priority": { "type": "string", "enum": ["Immediate", "UserBlocking", "Normal", "Low", "Idle"] },
                "lanes:mask": { "type": "string" },
                "w:pPr": { "$ref": "#/$defs/paragraphProperties" }
              },
              "required": ["ilvl"]
            }
          }
        },
        "required": ["abstractNumId", "levels"]
      }
    },
    "event_instances": {
      "type": "array",
      "description": "Sequential State Sync. Binds telemetry events to abstract numbering templates.",
      "items": {
        "type": "object",
        "properties": {
          "numId": { "type": "string" },
          "abstractNumId": { "type": "string" },
          "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "ac:cluster_id": { "type": "string" }
        },
        "required": ["numId", "abstractNumId"]
      }
    },
    "telemetry_fiber_tree": {
      "type": "array",
      "description": "Atomized Semantic Tree. Paragraph (Block Level API Context) and Run (Inline Level Metrics).",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["Block", "Inline"] },
          "fiber:tag": { "type": "integer" },
          "fiber:key": { "type": "string" },
          "w:pStyle": { "type": "string", "description": "Link to styles[styleId] or event_instances[numId]." },
          "pPr": { "$ref": "#/$defs/paragraphProperties" },
          "runs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rStyle": { "type": "string" },
                "rPr": { "$ref": "#/$defs/runProperties" },
                "lifecycle": {
                  "type": "object",
                  "properties": {
                    "render_phase": {
                      "type": "object",
                      "properties": {
                        "duration_ms": { "type": "number" },
                        "scheduler:yield_count": { "type": "integer" },
                        "lanes:active": { "type": "string" }
                      }
                    },
                    "commit_phase": {
                      "type": "object",
                      "properties": {
                        "duration_ms": { "type": "number" },
                        "mutation_count": { "type": "integer" },
                        "react:effect_tag": { "type": "string" }
                      }
                    }
                  }
                },
                "terminal": {
                  "type": "object",
                  "properties": {
                    "is_field": { "type": "boolean" },
                    "field_type": { "type": "string", "enum": ["COUNTER", "TIMER", "REF"] },
                    "value": { "type": "string" }
                  }
                }
              }
            }
          },
          "child": { "type": "array", "items": { "$ref": "#/properties/telemetry_fiber_tree/items" } }
        },
        "required": ["type"]
      }
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID Mapping). Decouples semantic logic from physical data targets.",
      "items": {
        "type": "object",
        "properties": {
          "rId": { "type": "string" },
          "type": { "type": "string", "format": "uri" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"] },
          "ac:verification_score": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["rId", "type", "target"]
      }
    }
  },
  "required": [
    "timestamp_ms",
    "settings",
    "telemetry_fiber_tree",
    "relationships"
  ],
  "$defs": {
    "paragraphProperties": {
      "type": "object",
      "properties": {
        "w:jc": { "type": "string", "enum": ["start", "center", "end", "both"] },
        "scheduler:priority": { "type": "string" },
        "fiber:lanes": { "type": "string" },
        "nx:governance_mode": { "type": "string", "enum": ["Strict", "Adaptive"] }
      }
    },
    "runProperties": {
      "type": "object",
      "properties": {
        "w:color": { "type": "string" },
        "w:sz": { "type": "integer" },
        "w:b": { "type": "boolean" },
        "react:memoize": { "type": "boolean" },
        "ac:complexity_constraint": { "type": "string" }
      }
    }
  }
}