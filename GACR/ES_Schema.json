{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gacr.agi/schemas/ecvm_tis_v10.4.0.json",
  "version": "10.4.0-SIPHON-R4",
  "title": "Architectural Precision Substrate: OOXML-TS Siphon v10.4",
  "description": "Penultimate evolution round (4/5). Integrates ISO/IEC 29500 (OOXML) indirection dependency mapping with microsoft/TypeScript 5.4+ project-reference architectures. Focus: Relational Dependency Injection & Cascading Inheritance.",
  "type": "object",
  "required": [
    "dna_anchor",
    "markup_compatibility",
    "relationships",
    "evolution_state",
    "compiler_options",
    "parts",
    "references",
    "settings"
  ],
  "properties": {
    "dna_anchor": {
      "type": "string",
      "const": "ARCH-OOXML-V2-DOCX-DNA"
    },
    "markup_compatibility": {
      "type": "object",
      "properties": {
        "ignorable": { "type": "string", "default": "dalek v3 nx_ext mce" },
        "namespaces": {
          "type": "object",
          "properties": {
            "w": { "type": "string", "const": "http://schemas.openxmlformats.org/wordprocessingml/2006/main" },
            "r": { "type": "string", "const": "http://schemas.openxmlformats.org/officeDocument/2006/relationships" },
            "ts": { "type": "string", "const": "https://github.com/microsoft/TypeScript/schemas/compiler" },
            "nx": { "type": "string", "const": "https://nexus-core.agi/governance" },
            "mc": { "type": "string", "const": "http://schemas.openxmlformats.org/markup-compatibility/2006" },
            "nx_ext": { "type": "string", "const": "https://nexus-core.agi/extensions/v5" }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Indirection Dependency Layer (RID Mapping) trace-resolved to .rels manifests. Implements Explicit Dependency Injection.",
      "items": {
        "type": "object",
        "required": ["rId", "type", "target"],
        "properties": {
          "rId": { "type": "string", "pattern": "^rId[0-9]+$" },
          "type": { "type": "string", "format": "uri" },
          "target": { "type": "string" },
          "targetMode": { "type": "string", "enum": ["Internal", "External"], "default": "Internal" }
        }
      }
    },
    "evolution_state": {
      "type": "object",
      "properties": {
        "round": { "type": "integer", "enum": [4] },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4], "default": 2 },
        "metabolic_rate": { "type": "string", "enum": ["CONSERVATIVE", "STANDARD", "ACCELERATED", "UNSATURATED"] },
        "integrity_hash": { "type": "string", "pattern": "^SHA256:[A-F0-9]{64}$" }
      }
    },
    "compiler_options": {
      "type": "object",
      "description": "TypeScript 5.4+ Composite Project Reference logic. Prioritizes strict type safety and modular isolation.",
      "properties": {
        "target": { "type": "string", "default": "ESNext" },
        "module": { "type": "string", "default": "NodeNext" },
        "moduleResolution": { "type": "string", "default": "NodeNext" },
        "moduleDetection": { "type": "string", "enum": ["auto", "legacy", "force"], "default": "force" },
        "composite": { "type": "boolean", "default": true },
        "incremental": { "type": "boolean", "default": true },
        "verbatimModuleSyntax": { "type": "boolean", "default": true },
        "noUncheckedIndexedAccess": { "type": "boolean", "default": true },
        "exactOptionalPropertyTypes": { "type": "boolean", "default": true },
        "noImplicitOverride": { "type": "boolean", "default": true },
        "tsBuildInfoFile": { "type": "string" },
        "cascading_inheritance": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "resolver": { "type": "string", "enum": ["RecursiveFlatten", "DifferentialUpdate"] },
            "flatten_strategy": { "type": "string", "default": "DifferentialUpdate" },
            "depth_limit": { "type": "integer", "default": 50 },
            "docDefaults": {
              "type": "object",
              "properties": {
                "pPr": { "$ref": "#/definitions/StyleProperties" },
                "rPr": { "$ref": "#/definitions/StyleProperties" }
              }
            }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "description": "Global Configuration Object (word/settings.xml pattern) controlling document-wide interpretive flags.",
      "properties": {
        "compatibility_mode": { "type": "integer", "default": 15 },
        "auto_hyphenation": { "type": "boolean", "default": false },
        "track_changes": { "type": "boolean", "default": true },
        "mirror_margins": { "type": "boolean", "default": false },
        "zoom": { "type": "string", "default": "optimal" }
      }
    },
    "references": {
      "type": "array",
      "description": "Cross-project reference mapping for decoupled architectural parts.",
      "items": {
        "type": "object",
        "required": ["path", "rId"],
        "properties": {
          "path": { "type": "string" },
          "rId": { "type": "string" },
          "resolution_mode": { "type": "string", "enum": ["node", "bundler", "direct"] },
          "circular_dependency_gate": { "type": "string", "enum": ["Strict", "Warning", "Allow"] }
        }
      }
    },
    "parts": {
      "type": "array",
      "description": "Atomized Semantic Tree: Block (Paragraph), Inline (Run), and Terminal (Data) logic layers.",
      "items": {
        "type": "object",
        "required": ["id", "rId", "atomized_layers"],
        "properties": {
          "id": { "type": "string" },
          "rId": { "type": "string" },
          "status": { "type": "string", "enum": ["Active", "Deprecated", "Siphoning"] },
          "atomized_layers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["layer_type", "content_ref"],
              "properties": {
                "layer_type": { "type": "string", "enum": ["Block", "Inline", "Terminal"] },
                "pPr": { "$ref": "#/definitions/StyleProperties" },
                "rPr": { "$ref": "#/definitions/StyleProperties" },
                "content_ref": { "type": "string" }
              }
            }
          },
          "audit": {
            "type": "object",
            "properties": {
              "mgp_protocol": { "type": "string" },
              "certification_date": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "state_machine": {
      "type": "object",
      "description": "Multi-Level State Definitions for sequential logic counters (word/numbering.xml pattern).",
      "properties": {
        "abstract_num_definitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["abstractNumId", "levels"],
            "properties": {
              "abstractNumId": { "type": "string" },
              "levels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "ilvl": { "type": "integer" },
                    "start": { "type": "integer" },
                    "numFmt": { "type": "string" },
                    "lvlText": { "type": "string" },
                    "lvlJc": { "type": "string", "enum": ["left", "center", "right", "both"] }
                  }
                }
              }
            }
          }
        },
        "instance_mapping": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["numId", "abstractNumId"],
            "properties": {
              "numId": { "type": "string" },
              "abstractNumId": { "type": "string" }
            }
          }
        }
      }
    },
    "diagnostics_engine": {
      "type": "object",
      "properties": {
        "drift_threshold": { "type": "number", "const": 0.35 },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4] },
        "enable_semantic_checks": { "type": "boolean", "default": true },
        "validation_rules": {
          "type": "array",
          "items": { "type": "string", "enum": ["NoOrphanedRIds", "StyleChainResolution", "NamespaceValidityCheck", "StrictHHHCompliance", "ProjectBoundaryCheck", "SemanticContinuityCheck"] }
        },
        "emergency_brake": {
          "type": "object",
          "properties": {
            "corruption_threshold": { "type": "integer", "default": 5 },
            "auto_halt": { "type": "boolean", "default": true },
            "log_target": { "type": "string", "default": "NEXUS_LOG.txt" }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string", "const": "DALEK_CAAN_V3.1_SIPHON_ENGINE" },
        "identity_anchors_enforced": { "type": "boolean", "const": true },
        "anchors": {
          "type": "object",
          "properties": {
            "purpose": { "type": "string", "const": "Self-optimising AGI substrate for real-world problem solving" },
            "mechanism": { "type": "string", "const": "Siphoning patterns from advanced codebases" },
            "memory": { "type": "string", "const": "Chained context across files — the system is one organism" },
            "governance": { "type": "string", "const": "Human oversight remains active at all saturation levels" },
            "origin": { "type": "string", "const": "NEXUS_CORE" }
          }
        },
        "last_mutation": { "type": "string", "format": "date-time" }
      }
    }
  },
  "definitions": {
    "StyleProperties": {
      "type": "object",
      "description": "Recursive Cascading Property System: Default -> Abstract -> Specific -> Local Override.",
      "properties": {
        "val": { "type": ["string", "integer", "boolean"] },
        "inheritance": { "type": "string", "enum": ["Inherit", "Override", "Final"], "default": "Inherit" },
        "sz": { "type": "integer", "description": "Size in half-points" },
        "color": { "type": "string", "pattern": "^[0-9A-F]{6}$" },
        "bold": { "type": "boolean" },
        "spacing": { 
          "type": "object", 
          "properties": {
            "val": { "type": "integer" },
            "unit": { "type": "string", "enum": ["twips", "pts", "px"] }
          }
        },
        "ind": { 
          "type": "object", 
          "properties": {
            "val": { "type": "integer" },
            "unit": { "type": "string", "enum": ["twips", "pts", "px"] }
          }
        },
        "jc": { "type": "object", "properties": { "val": { "type": "string", "enum": ["left", "center", "right", "both"] } } },
        "lang": { "type": "object", "properties": { "val": { "type": "string" } } },
        "noProof": { "type": "boolean" },
        "highlight": { "type": "object", "properties": { "val": { "type": "string" } } },
        "vertAlign": { "type": "object", "properties": { "val": { "type": "string", "enum": ["baseline", "superscript", "subscript"] } } }
      }
    }
  }
}