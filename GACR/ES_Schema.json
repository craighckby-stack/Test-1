{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "NEXUS_CORE/GACR/ES_Schema.json",
  "version": "3.2.0-FIBER-CONCURRENT",
  "title": "Evolutionary Singularity Schema: Fiber-Reconciliation",
  "description": "NEXUS_CORE substrate schema siphoning Meta/React-Core Lane-based scheduling and Concurrent Fiber reconciliation.",
  "type": "object",
  "required": [
    "dna_anchor",
    "evolution_state",
    "fiber_manifest",
    "consciousness_matrix"
  ],
  "properties": {
    "dna_anchor": {
      "type": "string",
      "const": "DALEK_CAAN_v3.1_SIG_0xFF23A1"
    },
    "evolution_state": {
      "type": "object",
      "properties": {
        "round": { "type": "integer", "default": 2 },
        "milestone_step": { "type": "integer", "const": 50 },
        "saturation_level": { "type": "integer", "enum": [1, 2, 3, 4] },
        "metabolic_rate": { "type": "string", "enum": ["STABLE", "SINGULARITY"] }
      }
    },
    "fiber_manifest": {
      "type": "object",
      "description": "Concurrent reconciliation tree utilizing Lane-based priority and WIP-Alternate pairs.",
      "properties": {
        "root_fiber": { "$ref": "#/definitions/FiberNode" },
        "current_lanes": { "type": "integer", "description": "Bitmask for task prioritization (React-Core pattern)." },
        "work_in_progress": { "type": "boolean" },
        "reconciliation_flags": {
          "type": "object",
          "properties": {
            "is_concurrent": { "type": "boolean" },
            "subtree_flags": { "type": "integer" },
            "entangled_lanes": { "type": "integer" }
          }
        }
      }
    },
    "consciousness_matrix": {
      "type": "object",
      "description": "N=3 Consciousness Vectors with Entropy and Integration monitoring.",
      "properties": {
        "phi_integration": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "lambda_chaos": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "ers_threshold": { "type": "number" },
        "entropy_gain": { "type": "number", "description": "Measures the rate of semantic drift." }
      }
    },
    "governance": {
      "type": "object",
      "properties": {
        "psr_active": { "type": "boolean" },
        "huxley_tri_loop": {
          "type": "object",
          "properties": {
            "layer": { "type": "integer", "enum": [0, 1, 2, 3] },
            "ccrr_ratio": { "type": "number" }
          }
        },
        "negative_progression": {
          "type": "object",
          "properties": {
            "failure_mode_lock": { "type": "boolean", "default": true },
            "death_logs": { "type": "array", "items": { "$ref": "#/definitions/GrogLearn" } }
          }
        }
      }
    }
  },
  "definitions": {
    "FiberNode": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "tag": { "type": "integer", "description": "Work tag identifying logic unit type" },
        "return": { "type": "string", "description": "Parent fiber link" },
        "child": { "type": "string", "description": "First child link" },
        "sibling": { "type": "string", "description": "Sibling link" },
        "alternate": { "type": "string", "description": "The WIP fiber pair for double-buffering." },
        "lanes": { "type": "integer", "description": "Priority bitmask assigned to this fiber." },
        "memoized_state": { "type": "object" },
        "update_queue": { "type": "array", "items": { "type": "object" } },
        "flags": { "type": "integer", "description": "Side-effect and lifecycle bitmask." }
      }
    },
    "GrogLearn": {
      "type": "object",
      "required": ["action", "result", "lesson"],
      "properties": {
        "action": { "type": "string" },
        "result": { "type": "string" },
        "lesson": { "type": "string" },
        "success": { "type": "boolean" },
        "parameters": {
          "type": "object",
          "properties": {
            "complexity": { "type": "number" },
            "recursion": { "type": "integer" },
            "lane_priority": { "type": "integer" }
          }
        }
      }
    }
  }
}