{
  "pkg:content-types": {
    "xmlns": "http://schemas.openxmlformats.org/package/2006/content-types",
    "overrides": [
      { "partName": "/_rels/.rels", "contentType": "application/vnd.openxmlformats-package.relationships+xml" },
      { "partName": "/word/document.xml", "contentType": "application/vnd.shadcn.nexus.document+xml" },
      { "partName": "/word/styles.xml", "contentType": "application/vnd.shadcn.nexus.styles+xml" },
      { "partName": "/word/theme/nexus-v10.xml", "contentType": "application/vnd.shadcn.nexus.theme+xml" },
      { "partName": "/word/numbering.xml", "contentType": "application/vnd.shadcn.nexus.numbering+xml" },
      { "partName": "/word/settings.xml", "contentType": "application/vnd.openxmlformats-officedocument.wordprocessingml.settings+xml" },
      { "partName": "/docProps/core.xml", "contentType": "application/vnd.openxmlformats-package.core-properties+xml" },
      { "partName": "/docProps/app.xml", "contentType": "application/vnd.openxmlformats-officedocument.extended-properties+xml" }
    ]
  },
  "pkg:rels": {
    "xmlns:r": "http://schemas.openxmlformats.org/package/2006/relationships",
    "relationships": [
      { "rId": "rId1", "type": "http://schemas.shadcn.com/logic/ui/form", "target": "@/components/ui/form", "integrity": "nexus-0x7F8E" },
      { "rId": "rId2", "type": "http://schemas.shadcn.com/logic/ui/input", "target": "@/components/ui/input", "integrity": "nexus-0xA1B2" },
      { "rId": "rId3", "type": "http://schemas.shadcn.com/logic/ui/button", "target": "@/components/ui/button", "integrity": "nexus-0xD4E5" },
      { "rId": "rId4", "type": "http://schemas.shadcn.com/logic/validation/zod", "target": "zod", "scope": "provider" },
      { "rId": "rId5", "type": "http://schemas.shadcn.com/logic/theme/nexus", "target": "/word/theme/nexus-v10.xml" },
      { "rId": "rId6", "type": "http://schemas.shadcn.com/logic/utils/cn", "target": "@/lib/utils" }
    ]
  },
  "pkg:document": {
    "xmlns:w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    "w:body": {
      "w:p": [
        {
          "w:pPr": { "w:pStyle": "nexus-header-saturated" },
          "w:r": [
            { "w:rPr": { "w:color": "hsl(var(--primary))", "w:sz": 52 }, "w:t": "Architectural Precision: Siphon Round 10" }
          ]
        },
        {
          "w:pPr": { "w:pStyle": "logic-container" },
          "w:r": [
            { "w:rPr": { "w:rStyle": "logic-bridge" }, "w:t": "Component::" },
            { "w:rPr": { "w:b": true, "w:color": "hsl(var(--accent-foreground))" }, "w:t": "FormLogicGate" },
            { "w:t": " initialized via " },
            { "w:rPr": { "w:i": true }, "w:t": "rId:4 (Zod Handshake)" },
            { "w:t": " -> Nexus Ready." }
          ]
        },
        {
          "w:pPr": { 
            "w:pStyle": "field-runway",
            "w:numPr": { "w:ilvl": 0, "w:numId": 1 } 
          },
          "w:r": [
            { "w:rPr": { "w:rStyle": "input-active-state" }, "w:t": "nexus-input-node" },
            { "w:rPr": { "w:rStyle": "attribute-meta" }, "w:t": " [variant='abstract-0'] " },
            { "w:t": " (Mapped::rId:2)" }
          ]
        },
        {
          "w:pPr": { "w:jc": { "w:val": "center" }, "w:spacing": { "w:before": 480 } },
          "w:r": { 
            "w:rPr": { "w:rStyle": "nexus-action-trigger", "w:rId": "rId3" }, 
            "w:t": "COMMIT_LOGIC_ASSEMBLY" 
          }
        }
      ],
      "w:sectPr": {
        "w:type": "nexus-evolution-final",
        "w:pgSz": { "w:w": 12240, "w:h": 15840 },
        "w:docVar": { 
          "engine_version": "3.1.Siphon", 
          "saturation_level": "MAX_CAPACITY",
          "runtime_integrity": "VERIFIED_RID_MAP"
        }
      }
    }
  },
  "pkg:styles": {
    "docDefaults": {
      "w:rPrDefault": {
        "w:rPr": {
          "w:rFonts": { "w:ascii": "Geist-Mono", "w:hAnsi": "Geist-Mono" },
          "w:sz": { "w:val": 24 },
          "w:color": { "w:val": "hsl(var(--foreground))" }
        }
      }
    },
    "definitions": [
      {
        "styleId": "nexus-root",
        "type": "paragraph",
        "w:name": { "w:val": "Nexus Base Inheritor" },
        "w:rPr": { "w:color": "slate-900" }
      },
      {
        "styleId": "nexus-header-saturated",
        "basedOn": "nexus-root",
        "type": "paragraph",
        "w:name": { "w:val": "Saturated Registry Header" },
        "w:pPr": { "w:outlineLvl": { "w:val": 0 }, "w:spacing": { "w:before": 600 } },
        "w:rPr": { "w:b": true, "w:sz": { "w:val": 64 }, "w:spacing": { "w:val": -25 } }
      },
      {
        "styleId": "logic-bridge",
        "type": "character",
        "w:name": { "w:val": "Nexus Logic Connector" },
        "w:rPr": { "w:color": "hsl(var(--primary))", "w:shd": { "w:val": "clear", "w:fill": "slate-50" } }
      },
      {
        "styleId": "input-active-state",
        "basedOn": "logic-bridge",
        "type": "character",
        "w:name": { "w:val": "Nexus Input State Run" },
        "w:rPr": { "w:u": { "w:val": "single" }, "focus": "ring-nexus-ultra" }
      },
      {
        "styleId": "nexus-action-trigger",
        "type": "character",
        "w:name": { "w:val": "Nexus Deployment Run" },
        "w:rPr": { "w:b": true, "w:sz": { "w:val": 36 }, "w:shd": { "w:val": "pct25", "w:fill": "primary" } }
      }
    ]
  },
  "pkg:numbering": {
    "abstractDefs": [
      {
        "abstractNumId": 0,
        "w:lvl": [
          { 
            "w:ilvl": 0, 
            "w:start": { "w:val": 1 }, 
            "w:numFmt": { "w:val": "decimal" }, 
            "w:lvlText": { "w:val": "NexusNode[%1]:" },
            "w:pPr": { "w:ind": { "w:left": 720, "w:hanging": 360 } }
          }
        ]
      }
    ],
    "numInstances": [
      { "numId": 1, "abstractNumId": { "w:val": 0 } }
    ]
  },
  "docProps": {
