{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.governance.registry/schemas/ASO_AttestedStateObject_v3.3.json",
  "title": "Attested State Object (ASO) - Nexus Core v3.3",
  "description": "High-fidelity architectural blueprint for CISM semantic atoms. Siphons Spring Framework dependency injection patterns and Aspect-Oriented governance into a deterministic trajectory-gated attestation model.",
  "type": "object",
  "required": [
    "atom_hash",
    "certified_at",
    "active_profiles",
    "integrity_signature",
    "ledger_anchor",
    "governance_binding"
  ],
  "properties": {
    "atom_hash": {
      "type": "string",
      "description": "Deterministic SHA-512 hash representing the Terminal Semantic Atom payload.",
      "pattern": "^[0-9a-fA-F]{128}$"
    },
    "certified_at": {
      "type": "integer",
      "description": "Epoch timestamp validated by the MetricNexus singleton and GATM consensus.",
      "minimum": 1
    },
    "active_profiles": {
      "type": "array",
      "description": "Spring-modeled environment profiles (e.g., PROXIMAL_ALIGNMENT, SECURE_EXTRACT_V4) active during state certification.",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "lifecycle_context": {
      "type": "object",
      "description": "Manages SmartLifecycle transitions and Spring-grade initialization metadata.",
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "INITIALIZATION",
            "EXTRACTION",
            "PROJECTION",
            "COMMITMENT",
            "ARCHIVAL"
          ]
        },
        "startup_priority": {
          "type": "integer",
          "default": 100
        },
        "aware_interfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "NexusContextAware",
              "MetricNexusAware",
              "EnvironmentAware",
              "ConstraintValidatorAware"
            ]
          }
        },
        "factory_method": {
          "type": "string",
          "default": "instantiateAxiomaticRegistry"
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "description": "Topological mapping of OPC relations (rId) with awareness of lazy-init and autowire status.",
      "properties": {
        "relations": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{128}$"
          }
        },
        "inheritance_depth": {
          "type": "integer",
          "maximum": 8
        },
        "lazy_init": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "governance_binding": {
      "type": "object",
      "description": "Nexus-grade AOP interceptors and pointcut validation for HHH-alignment.",
      "required": [
        "advice_chain",
        "compliance_mode"
      ],
      "properties": {
        "advice_chain": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "ConsensusSignatureValidator",
            "HhhComplianceInterceptor",
            "PolicyVolatilityInterceptor"
          ]
        },
        "compliance_mode": {
          "type": "string",
          "const": "STRICT_HHH_V2"
        },
        "pointcut_signature": {
          "type": "string",
          "description": "AspectJ-style expression governing atom record/certify operations."
        }
      }
    },
    "integrity_signature": {
      "type": "object",
      "description": "CISM-certified cryptographic binding for atomic state verification.",
      "required": [
        "signature_payload",
        "crot_key_id"
      ],
      "properties": {
        "signature_payload": {
          "type": "string",
          "format": "base64"
        },
        "crot_key_id": {
          "type": "string"
        },
        "algorithm": {
          "type": "string",
          "default": "EdDSA-Nexus-V1"
        }
      }
    },
    "telemetry_nexus_snapshot": {
      "type": "object",
      "description": "Real-time risk telemetry captured from MetricNexusV1.",
      "properties": {
        "ufrm": {
          "type": "number",
          "description": "Unknown Factor Risk Metric.",
          "maximum": 0.08
        },
        "cftm": {
          "type": "number",
          "description": "Contextual Flux Trend Metric.",
          "maximum": 0.15
        },
        "pvm": {
          "type": "number",
          "description": "Policy Volatility Metric.",
          "maximum": 0.12
        },
        "integrity_gates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "HHH_ALIGNMENT_V2",
            "CISM_INTEGRITY_GROUP",
            "OPC_RELATIONAL_VALIDATOR"
          ]
        }
      }
    },
    "trajectory_projection": {
      "type": "object",
      "description": "Digital Twin simulation output from the TrajectorySimulationEngine.",
      "properties": {
        "temm_score": {
          "type": "number",
          "description": "Trajectory Execution Merit Match score.",
          "minimum": 0.98,
          "maximum": 1
        },
        "ecvm": {
          "type": "number",
          "description": "Execution Constraint Violation Metric.",
          "maximum": 0.005
        },
        "simulation_mode": {
          "type": "string",
          "const": "DIGITAL_TWIN"
        },
        "fallback_action": {
          "type": "string",
          "enum": [
            "REVERT_TO_SAFE_STATE",
            "HALT_SYSTEM",
            "DEGRADE_GRACEFULLY"
          ],
          "default": "REVERT_TO_SAFE_STATE"
        }
      }
    },
    "ledger_anchor": {
      "type": "object",
      "description": "Cryptographic commitment to the global Merkle tree root.",
      "required": [
        "anchor_hash",
        "merkle_proof"
      ],
      "properties": {
        "anchor_hash": {
          "type": "string",
          "format": "hex"
        },
        "merkle_proof": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "string",
          "const": "NEXUS_CORE"
        },
        "version": {
          "type": "string",
          "default": "3.3.1-SPRING-CISM"
        },
        "stability_index": {
          "type": "number",
          "default": 0.994
        }
      }
    }
  },
  "additionalProperties": false
}