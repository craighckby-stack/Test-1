{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Governance Data Execution & Constraint Model (GDECM) - Nexus Core v3.1 - ARCH-OOXML-V2-DOCX-DNA",
  "definitions": {
    "AdviceChain": {
      "type": "object",
      "properties": {
        "pointcut": { "type": "string", "description": "SpEL join-point expression" },
        "interceptors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "order": { "type": "integer", "default": 0 }
      }
    },
    "ResourceDescriptor": {
      "type": "object",
      "properties": {
        "uri": { "type": "string" },
        "scope": { "type": "string", "enum": ["SINGLETON", "PROTOTYPE", "REQUEST"], "default": "SINGLETON" },
        "lazy_init": { "type": "boolean", "default": false },
        "resolver": { "type": "string", "default": "DefaultSiphonResolver" }
      },
      "required": ["uri"]
    }
  },
  "properties": {
    "environment_context": {
      "type": "object",
      "properties": {
        "namespace": { "type": "string", "default": "nexus.internal" },
        "parent_context": { "type": ["string", "null"] },
        "active_profiles": { "type": "array", "items": { "type": "string" } },
        "telemetry_nexus": {
          "type": "object",
          "properties": {
            "binding": { "type": "string", "default": "MetricNexusV1" },
            "critical_thresholds": {
              "type": "object",
              "properties": {
                "max_pvm": { "type": "number", "description": "Policy Volatility Metric" },
                "max_ufrm": { "type": "number", "description": "Unknown Factor Risk Metric" },
                "max_cftm": { "type": "number", "description": "Contextual Flux Trend Metric" }
              }
            }
          }
        }
      }
    },
    "abstract_templates": {
      "type": "array",
      "description": "Recursive Cascading templates for stage inheritance",
      "items": { "$ref": "#/properties/stages/items" }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "parent": { "type": "string", "description": "Bean-style inheritance pointer" },
          "abstract": { "type": "boolean", "default": false },
          "condition": { "type": "string", "description": "SpEL deployment condition" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "resource_dependencies": {
            "type": "array",
            "items": { "$ref": "#/definitions/ResourceDescriptor" }
          },
          "advice_chain": { "$ref": "#/definitions/AdviceChain" },
          "governance_policy": {
            "type": "object",
            "properties": {
              "hhh_enforcement": { "type": "boolean", "default": true },
              "axiomatic_verification": { "type": "string", "enum": ["STRICT", "LAX", "SIMULATED"], "default": "STRICT" },
              "simulation_strategy": { 
                "type": "object",
                "properties": {
                  "mode": { "type": "string", "enum": ["BLOCKING", "SHADOW_SIM", "HEURISTIC"], "default": "BLOCKING" },
                  "depth": { "type": "integer", "default": 3 },
                  "max_drift": { "type": "number", "default": 0.15 }
                }
              }
            }
          },
          "post_processors": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id"]
      }
    }
  },
  "required": ["stages", "environment_context"]
}