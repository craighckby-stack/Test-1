{
  "id": "CertifiedIntermediateStateRegistry",
  "role": "INFRASTRUCTURE",
  "qualifiers": [
    "CISM_CUSTODIAN",
    "IMMUTABILITY_LOCK_PROVIDER",
    "NEXUS_PRIMARY"
  ],
  "scope": "SINGLETON",
  "profiles": [
    "PRODUCTION",
    "GOVERNANCE_STRICT"
  ],
  "abstract": false,
  "lazy_init": false,
  "primary": true,
  "autowire_candidate": true,
  "factory_method": "instantiateAxiomaticRegistry",
  "depends_on": [
    "AxiomaticEventBroadcaster",
    "MetricNexusV1",
    "MerkleTreeProvider",
    "ConstraintAdherenceValidator"
  ],
  "resource_dependencies": [
    {
      "id": "CISM_SNAPSHOT_STORE",
      "type": "PERSISTENT_STATE",
      "uri": "nexus://storage/cism/certified",
      "required": true,
      "description": "Deterministic OPC relational model storage for state atoms"
    }
  ],
  "lifecycle": {
    "init_method": "onBootstrap",
    "destroy_method": "onHalt",
    "startup_priority": 100
  },
  "advice_chain": {
    "interceptors": [
      "ConsensusSignatureValidator",
      "HhhComplianceInterceptor",
      "PolicyVolatilityInterceptor"
    ],
    "order": -2147483648,
    "pointcut_expression": "execution(* nexus.core.CISR.*(..))"
  },
  "post_processors": [
    {
      "id": "MerkleRootGenerator",
      "type": "INTEGRITY",
      "priority": 1,
      "action": "COMPUTE_TERMINAL_HASH"
    },
    {
      "id": "PolicyVolatilityAuditor",
      "type": "GOVERNANCE",
      "priority": 2,
      "threshold_impact": "PVM_CASCADING"
    }
  ],
  "semantic_atom_config": {
    "strategy": "DeterministicOOXML",
    "traversal": "DEEP_GRAPH",
    "inheritance_depth": 8,
    "mapping_service": "TerminalAtomConversionService"
  },
  "governance_policy": {
    "enforcement": "STRICT",
    "validation_groups": [
      "GEDM_PRE_FLIGHT",
      "CISM_INTEGRITY_GROUP",
      "HHH_ALIGNMENT_V2"
    ],
    "simulation": {
      "mode": "DIGITAL_TWIN",
      "model_handler": "TrajectorySimulationEngine",
      "depth": 5,
      "temm_min_score": 0.98,
      "ufrm_limit": 0.10,
      "cftm_limit": 0.05,
      "ecvm_threshold": 0.005,
      "stochastic_variance": 0.02,
      "fallback_action": "REVERT_TO_SAFE_STATE"
    }
  },
  "interface_manifest": {
    "RegisterStateSnapshot": {
      "input_mapping": {
        "state_map": "IntermediateStateMap",
        "signature": "VerifierSignature"
      },
      "output_mapping": {
        "m_pointer": "CISM_Reference_Pointer",
        "root_hash": "RootHash"
      },
      "constraints": [
        "HHH_ALIGNED",
        "HASH_LOCKED",
        "UFRM_WITHIN_BOUNDS"
      ]
    },
    "RetrieveReference": {
      "input_mapping": {
        "uid": "StateUID",
        "hash": "ExpectedRootHash"
      },
      "integrity_gate": "AxiomaticConstraintValidator",
      "security_mandate": "ROOT_HASH_MUST_MATCH_REGISTERED",
      "telemetry_link": "MetricNexusV1"
    }
  },
  "metadata": {
    "purpose": "Ensure immutable, hash-locked availability of all CISM snapshots required for GEDM validation.",
    "origin": "NEXUS_CORE",
    "version": "3.1.2-SYNTH",
    "architectural_pattern": "RecursiveCascadingInheritance"
  }
}