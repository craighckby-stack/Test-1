{
  "id": "CertifiedIntermediateStateRegistry",
  "role": "INFRASTRUCTURE",
  "qualifiers": [
    "CISM_CUSTODIAN",
    "IMMUTABILITY_LOCK_PROVIDER"
  ],
  "scope": "SINGLETON",
  "abstract": false,
  "lazy_init": false,
  "primary": true,
  "autowire_candidate": true,
  "depends_on": [
    "AxiomaticEventBroadcaster",
    "MetricNexusV1",
    "MerkleTreeProvider"
  ],
  "resource_dependencies": [
    {
      "id": "CISM_SNAPSHOT_STORE",
      "type": "PERSISTENT_STATE",
      "uri": "nexus://storage/cism/certified",
      "required": true
    }
  ],
  "lifecycle": {
    "init_method": "onBootstrap",
    "destroy_method": "onHalt"
  },
  "advice_chain": {
    "interceptors": [
      "ConsensusSignatureValidator",
      "HhhComplianceInterceptor"
    ],
    "order": 0
  },
  "post_processors": [
    {
      "id": "MerkleRootGenerator",
      "type": "INTEGRITY",
      "priority": 1
    },
    {
      "id": "PolicyVolatilityAuditor",
      "type": "GOVERNANCE",
      "priority": 2
    }
  ],
  "semantic_atom_config": {
    "strategy": "DeterministicOOXML",
    "traversal": "DEEP_GRAPH",
    "inheritance_depth": 8
  },
  "governance_policy": {
    "enforcement": "STRICT",
    "validation_groups": [
      "GEDM_PRE_FLIGHT",
      "CISM_INTEGRITY_GROUP"
    ],
    "simulation": {
      "mode": "SHADOW_SIM",
      "model_handler": "PredictiveModelStub",
      "depth": 5,
      "temm_min_score": 0.95,
      "ufrm_limit": 0.12,
      "cftm_limit": 0.08,
      "ecvm_threshold": 0.01,
      "fallback_action": "REVERT_TO_SAFE_STATE"
    }
  },
  "interface_manifest": {
    "RegisterStateSnapshot": {
      "input_mapping": {
        "state_map": "IntermediateStateMap",
        "signature": "VerifierSignature"
      },
      "output_mapping": {
        "m_pointer": "CISM_Reference_Pointer",
        "root_hash": "RootHash"
      },
      "constraints": [
        "HHH_ALIGNED",
        "HASH_LOCKED"
      ]
    },
    "RetrieveReference": {
      "input_mapping": {
        "uid": "StateUID",
        "hash": "ExpectedRootHash"
      },
      "integrity_gate": "AxiomaticConstraintValidator",
      "security_mandate": "ROOT_HASH_MUST_MATCH_REGISTERED"
    }
  },
  "metadata": {
    "purpose": "Ensure immutable, hash-locked availability of all CISM snapshots required for GEDM validation.",
    "origin": "NEXUS_CORE",
    "version": "3.1.0-SYNTH"
  }
}