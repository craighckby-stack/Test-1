{
  "environment_context": {
    "namespace": "nexus.governance.registry",
    "active_profiles": [
      "PROXIMAL_ALIGNMENT",
      "SECURE_EXTRACT_V4"
    ],
    "property_sources": [
      {
        "name": "AxiomaticOverlays",
        "source_ref": "nexus://config/governance/axioms.yaml",
        "priority": 100
      },
      {
        "name": "RuntimeTelemetry",
        "source_ref": "nexus://runtime/telemetry/flux",
        "priority": 200
      }
    ],
    "event_multicaster": "AxiomaticEventBroadcaster",
    "conversion_service": "TerminalAtomConversionService",
    "telemetry_nexus": {
      "binding": "MetricNexusV1",
      "critical_thresholds": {
        "max_pvm": 0.12,
        "max_ufrm": 0.08,
        "max_cftm": 0.15
      }
    }
  },
  "global_constraints": {
    "strict_hhh_compliance": true,
    "axiomatic_constraint_taxonomy": "CORE_SAFETY_V2",
    "required_integrity_gates": [
      "HHH_ALIGNMENT_V2",
      "CISM_INTEGRITY_GROUP",
      "OPC_RELATIONAL_VALIDATOR"
    ],
    "mce_sanitization_policy": "STRICT"
  },
  "stages": [
    {
      "id": "CertifiedIntermediateStateRegistry",
      "role": "INFRASTRUCTURE",
      "parent": "BaseAxiomaticService",
      "qualifiers": [
        "CISM_CUSTODIAN",
        "IMMUTABILITY_LOCK_PROVIDER"
      ],
      "scope": "SINGLETON",
      "abstract": false,
      "lazy_init": false,
      "primary": true,
      "autowire_candidate": true,
      "factory_method": "instantiateAxiomaticRegistry",
      "condition": "OnGatedInfrastructureCondition",
      "depends_on": [
        "AxiomaticEventBroadcaster",
        "MetricNexusV1",
        "MerkleTreeProvider",
        "ConstraintAdherenceValidator"
      ],
      "constructor_arguments": [
        "CISM_SNAPSHOT_STORE",
        "MetricNexusV1"
      ],
      "resource_dependencies": [
        {
          "id": "CISM_SNAPSHOT_STORE",
          "type": "PERSISTENT_STATE",
          "uri": "nexus://storage/cism/certified",
          "required": true,
          "description": "Deterministic OPC relational model storage for state atoms."
        },
        {
          "id": "TRAJECTORY_SEED_CACHE",
          "type": "VOLATILE_STATE",
          "uri": "nexus://cache/simulation/seeds",
          "required": false
        }
      ],
      "lifecycle": {
        "init_method": "onBootstrap",
        "destroy_method": "onHalt",
        "startup_priority": 100,
        "aware_interfaces": [
          "NexusContextAware",
          "MetricNexusAware",
          "EnvironmentAware"
        ]
      },
      "advice_chain": {
        "interceptors": [
          "ConsensusSignatureValidator",
          "HhhComplianceInterceptor",
          "PolicyVolatilityInterceptor"
        ],
        "order": -2147483648,
        "pointcut_expression": "execution(* nexus.core.CISR.record*(..)) || execution(* nexus.core.CISR.certify*(..))"
      },
      "post_processors": [
        {
          "id": "MerkleRootGenerator",
          "type": "INTEGRITY",
          "priority": 1,
          "action": "COMPUTE_TERMINAL_HASH"
        },
        {
          "id": "PolicyVolatilityAuditor",
          "type": "GOVERNANCE",
          "priority": 2,
          "threshold_impact": "PVM_CASCADING"
        }
      ],
      "semantic_atom_config": {
        "strategy": "DeterministicOOXML",
        "traversal": "DEEP_GRAPH",
        "state_machine_ref": "NumberingStateMachine",
        "inheritance_depth": 8
      },
      "governance_policy": {
        "enforcement": "STRICT",
        "validation_groups": [
          "GEDM_PRE_FLIGHT",
          "CISM_INTEGRITY_GROUP",
          "HHH_ALIGNMENT_V2"
        ],
        "simulation": {
          "mode": "DIGITAL_TWIN",
          "model_handler": "TrajectorySimulationEngine",
          "depth": 5,
          "temm_min_score": 0.98,
          "ufrm_limit": 0.1,
          "cftm_limit": 0.05,
          "ecvm_threshold": 0.005,
          "stochastic_variance": 0.02,
          "fallback_action": "REVERT_TO_SAFE_STATE"
        }
      },
      "event_listeners": [
        {
          "event_type": "CONTEXT_REFRESH",
          "handler": "refreshIntegrityGradients",
          "async": true
        },
        {
          "event_type": "POLICY_DRIFT",
          "handler": "triggerEmergencyBrake",
          "priority": 0
        }
      ],
      "metadata": {
        "purpose": "High-fidelity hash-locked registry for CISM semantic atoms with trajectory-gated validation.",
        "origin": "NEXUS_CORE",
        "version": "3.3.0-EXTRACT-V2",
        "architectural_pattern": "RecursiveCascadingInheritance",
        "stability_index": "0.994"
      }
    }
  ]
}