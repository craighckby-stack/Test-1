{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://governance.agi/gedm/protocol/constraint-schema-v5.0.json",
  "title": "GEDM Governance Data Execution & Constraint Model (GDECM) - Final Synthesis",
  "description": "Nexus-grade AGI Trajectory Synthesis schema. Siphons Spring-Framework IoC paradigms (BeanDefinition, Lifecycle, ProxyConfig) into ARCH-OOXML-V2-DOCX-DNA governance. Enforces Axiomatic Constraint Adherence via Digital Twin simulation.",
  "definitions": {
    "AxiomaticContextEvent": {
      "type": "object",
      "properties": {
        "event_type": { "type": "string" },
        "pvm_impact": { "type": "number" },
        "expression_filter": { "type": "string", "description": "SpEL filter for event propagation" },
        "broadcast_scope": { "type": "string", "enum": ["LOCAL", "GLOBAL", "NEXUS"], "default": "LOCAL" }
      }
    },
    "IntegrityCheck": {
      "type": "object",
      "required": ["method", "expected_hash"],
      "properties": {
        "method": { "type": "string", "enum": ["SHA256", "PGP_Signature", "TimeLock_Hash"], "default": "SHA256" },
        "expected_hash": { "type": "string" }
      }
    },
    "AdviceChain": {
      "type": "object",
      "properties": {
        "pointcut": { "type": "string" },
        "advice_type": { "type": "string", "enum": ["BEFORE", "AFTER", "AROUND", "AFTER_THROWING"], "default": "AROUND" },
        "interceptors": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "integer", "default": 0 },
        "proxy_mode": { "type": "string", "enum": ["INTERFACES", "TARGET_CLASS", "NO"], "default": "TARGET_CLASS" }
      }
    },
    "MutationPostProcessor": {
      "type": "object",
      "properties": {
        "ref": { "type": "string" },
        "order": { "type": "integer", "default": 0 },
        "applicability_filter": { "type": "string" }
      }
    },
    "ResourceDescriptor": {
      "type": "object",
      "required": ["uri", "artifact_id"],
      "properties": {
        "artifact_id": { "type": "string" },
        "version": { "type": "string" },
        "uri": { "type": "string" },
        "protocol": { "type": "string", "enum": ["classpath", "file", "s3", "nexus-siphon"], "default": "nexus-siphon" },
        "media_type": { "type": "string", "default": "application/vnd.openxmlformats-officedocument" },
        "integrity": { "$ref": "#/definitions/IntegrityCheck" },
        "resolver_ref": { "type": "string", "default": "CascadingStyleResolver" }
      }
    },
    "LifecycleHooks": {
      "type": "object",
      "properties": {
        "init_method": { "type": "string" },
        "destroy_method": { "type": "string" },
        "aware_interfaces": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["NEXUS_CONTEXT", "METRIC_NEXUS", "TRAJECTORY_ENGINE", "GOVERNANCE_REGISTRY", "ENVIRONMENT_AWARE"] } 
        },
        "on_violation": { "type": "string", "description": "ECVM breach recovery handler" },
        "circuit_breaker_ref": { "type": "string" }
      }
    },
    "TrajectorySimulation": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["BLOCKING", "SHADOW_SIM", "HEURISTIC", "DIGITAL_TWIN"], "default": "SHADOW_SIM" },
        "model_handler": { "type": "string", "default": "PredictiveModelStub" },
        "depth": { "type": "integer", "default": 3 },
        "temm_min_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "ufrm_limit": { "type": "number" },
        "cftm_limit": { "type": "number" },
        "ecvm_threshold": { "type": "number" },
        "stochastic_variance": { "type": "number", "default": 0.05 },
        "fallback_action": { "type": "string", "default": "REVERT_TO_SAFE_STATE" }
      }
    },
    "PropertySource": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "source_ref": { "type": "string" },
        "priority": { "type": "integer" }
      }
    }
  },
  "type": "object",
  "required": ["stages", "environment_context", "global_constraints"],
  "properties": {
    "environment_context": {
      "type": "object",
      "properties": {
        "namespace": { "type": "string", "default": "nexus.internal" },
        "active_profiles": { "type": "array", "items": { "type": "string" } },
        "property_sources": { "type": "array", "items": { "$ref": "#/definitions/PropertySource" } },
        "event_multicaster": { "type": "string", "default": "AxiomaticEventBroadcaster" },
        "conversion_service": { "type": "string", "description": "Semantic type mapping for terminal atoms" },
        "telemetry_nexus": {
          "type": "object",
          "properties": {
            "binding": { "type": "string", "default": "MetricNexusV1" },
            "critical_thresholds": {
              "type": "object",
              "properties": {
                "max_pvm": { "type": "number" },
                "max_ufrm": { "type": "number" },
                "max_cftm": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "global_constraints": {
      "type": "object",
      "properties": {
        "strict_hhh_compliance": { "type": "boolean", "default": true },
        "axiomatic_constraint_taxonomy": { "type": "string", "default": "CORE_SAFETY_V2" },
        "required_integrity_gates": { "type": "array", "items": { "type": "string" } },
        "mce_sanitization_policy": { "type": "string", "enum": ["STRICT", "PASS_THROUGH"], "default": "STRICT" }
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string", "enum": ["APPLICATION", "INFRASTRUCTURE", "SUPPORT"], "default": "APPLICATION" },
          "parent": { "type": "string" },
          "qualifiers": { "type": "array", "items": { "type": "string" } },
          "scope": { "type": "string", "enum": ["SINGLETON", "PROTOTYPE", "CONTEXTUAL", "THREAD"], "default": "SINGLETON" },
          "abstract": { "type": "boolean", "default": false },
          "lazy_init": { "type": "boolean", "default": false },
          "primary": { "type": "boolean", "default": false },
          "autowire_candidate": { "type": "boolean", "default": true },
          "factory_method": { "type": "string" },
          "constructor_arguments": { "type": "array", "items": { "type": "string" } },
          "condition": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "resource_dependencies": {
            "type": "array",
            "items": { "$ref": "#/definitions/ResourceDescriptor" }
          },
          "lifecycle": { "$ref": "#/definitions/LifecycleHooks" },
          "advice_chain": { "$ref": "#/definitions/AdviceChain" },
          "post_processors": { "type": "array", "items": { "$ref": "#/definitions/MutationPostProcessor" } },
          "event_listeners": { "type": "array", "items": { "$ref": "#/definitions/AxiomaticContextEvent" } },
          "semantic_atom_config": {
            "type": "object",
            "properties": {
              "strategy": { "type": "string", "default": "DeterministicOOXML" },
              "traversal": { "type": "string", "enum": ["LAZY", "EAGER", "DEEP_GRAPH"], "default": "LAZY" },
              "state_machine_ref": { "type": "string" },
              "inheritance_depth": { "type": "integer", "default": 5 }
            }
          },
          "governance_policy": {
            "type": "object",
            "properties": {
              "enforcement": { "type": "string", "enum": ["STRICT", "LAX", "SIMULATED"], "default": "STRICT" },
              "validation_groups": { "type": "array", "items": { "type": "string" } },
              "simulation": { "$ref": "#/definitions/TrajectorySimulation" }
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}